# Large binary assets — keep locally, do not push to GitHub
ASSETS/

# CMS image uploads are TRACKED on purpose: Hostinger deploys reset the app
# directory to the repo state, so any upload not in git is destroyed on the
# next deploy (this killed every cover image uploaded before 2026-07-06).

# Editor runtime state
src/_data/_edits.json
.sessions.json

# Temp / OS files
*.tmp
*.bak
~$*

# Large media — upload manually to Hostinger via File Manager
public/images/activities/
public/images/team/
public/images/events/
# blog cover images are small .avif files (~300KB total) — tracked in git
public/videos/
public/fonts/
