{
  "name": "akadigital-web",
  "version": "1.0.0",
  "description": "AKA Digital — B2B MarTech Agency Website for Southeast Asia",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node editor-server.js",
    "postinstall": "npm run build",
    "dev": "concurrently \"npm run css:watch\" \"eleventy --serve --port=3000\"",
    "editor": "node editor-server.js",
    "editor:dev": "concurrently \"npm run css:watch\" \"eleventy --watch\" \"node editor-server.js\"",
    "build": "npm run css:build && node node_modules/@11ty/eleventy/cmd.cjs",
    "test:security": "node --test tests/security.test.js",
    "backup": "node scripts/backup-site.js",
    "css:build": "node node_modules/tailwindcss/lib/cli.js -i src/styles/main.css -o public/css/main.css --minify",
    "css:watch": "tailwindcss -i src/styles/main.css -o public/css/main.css --watch",
    "export:css": "node -e \"require('fs').mkdirSync('exports/css',{recursive:true})\" && cp public/css/main.css exports/css/main.css",
    "export:json": "node -e \"const fs=require('fs');fs.mkdirSync('exports/json',{recursive:true});fs.readdirSync('src/_data').forEach(f=>fs.copyFileSync('src/_data/'+f,'exports/json/'+f))\"",
    "export:assets": "node scripts/export-assets.js",
    "export:build": "npm run build && node scripts/export-build.js",
    "export:all": "npm run export:css && npm run export:json && npm run export:assets && npm run export:build"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@anthropic-ai/sdk": "^0.110.0",
    "@composio/core": "^0.13.1",
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.5.4",
    "basic-ftp": "^5.3.1",
    "concurrently": "^9.0.0",
    "heic-convert": "^2.1.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.10"
  }
}
