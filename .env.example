PORT=3001
ADMIN_USER=admin
ADMIN_PASS=change-me
TEAM_USER=team
TEAM_PASS=change-me
GOOGLE_CLIENT_ID=
CMS_USERS_FILE=
# Comma-separated Gmail addresses that are ALWAYS super admin, independent of
# cms_users.json (survives that file being lost/edited). e.g.:
# SUPER_ADMIN_EMAILS=jeffrey.teo@akadigital.net,khoa.nguyen@akadigital.net,phuong.pham@akadigital.net
SUPER_ADMIN_EMAILS=
# Set to "true" once every super admin can sign in with Google, to retire the
# shared ADMIN_USER/ADMIN_PASS + TEAM_USER/TEAM_PASS password login. Flip back
# to false/unset at any time (no redeploy) as an emergency fallback.
DISABLE_PASSWORD_LOGIN=false
FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_DIR=/public_html
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://www.akadigital.net,https://akadigital.net
SESSION_TTL_MS=1800000
