      <div class="card p-8 hover:border-primary/40 hover:shadow-[0_8px_32px_rgba(37,59,194,0.08)] transition-all duration-300 group">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
          <span class="material-symbols-outlined text-primary group-hover:text-on-primary transition-colors text-2xl" style="font-variation-settings:'FILL' 1">monitoring</span>
        </div>
        <h3 class="font-display font-bold text-on-surface text-headline-sm mb-3">Revenue Attribution</h3>
        <p class="text-body-md text-on-surface-variant leading-relaxed">Close the loop between campaigns and revenue. Know exactly which journey step drove which conversion — down to the dollar.</p>
      </div>
    </div>
  </div>
</section>


<!-- ============================================================
     CRM MATURITY AUDIT — Lead Gen Form
     ============================================================ -->
<section class="py-20 md:py-28 bg-background relative overflow-hidden" id="audit-form">
  <div class="absolute inset-0 opacity-[0.03]" style="background-image:radial-gradient(ellipse at 20% 50%, rgba(37,59,194,0.8) 0%, transparent 60%)"></div>
  <div class="relative z-10 section-container">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="inline-block bg-action-yellow text-on-secondary-fixed text-label-md font-bold px-4 py-1.5 rounded-full mb-4 uppercase tracking-wider">Free Assessment</span>
        <h2 class="text-headline-md md:text-headline-lg font-display text-on-surface mb-4 text-balance">Get Your CRM Maturity Audit</h2>
        <p class="text-body-lg text-on-surface-variant max-w-xl mx-auto">Find out exactly where your tech stack is leaking revenue. Our experts will perform a deep dive into your current setup and deliver a prioritised action plan.</p>
      </div>

      <!-- What's included checklist -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {% set audit_items = ["Current tech stack evaluation", "Audience segmentation depth", "Journey automation sophistication", "Revenue attribution capability", "Personalisation maturity score"] %}
        {% for item in audit_items %}
          <div class="flex items-center gap-2 bg-surface-off-white border border-outline-variant/20 rounded-full px-4 py-2">
            <span class="material-symbols-outlined text-primary text-base" style="font-variation-settings:'FILL' 1">check_circle</span>
            <span class="text-label-md text-on-surface font-medium">{{ item }}</span>
          </div>
        {% endfor %}
      </div>

      <!-- Form card -->
      <div class="bg-surface-off-white border border-outline-variant/20 rounded-3xl p-8 md:p-12 shadow-[0_4px_40px_rgba(0,0,0,0.06)]">
        <form class="grid md:grid-cols-2 gap-x-8 gap-y-6" name="crm-audit" action="https://formsubmit.co/phuong.pham@akadigital.net" method="POST">
          <input type="hidden" name="_subject" value="CRM Maturity Audit Request — AKA Digital">
          <input type="hidden" name="_template" value="table">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_next" value="https://akadigital.net/solutions/crm-automation/?submitted=true">
          <div class="flex flex-col gap-2">
            <label class="text-label-md text-on-surface-variant uppercase tracking-wider">Full Name <span class="text-error">*</span></label>
            <input type="text" name="name" placeholder="Your full name" required class="input-field" />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-label-md text-on-surface-variant uppercase tracking-wider">Work Email <span class="text-error">*</span></label>
            <input type="email" name="email" placeholder="you@company.com" required class="input-field" />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-label-md text-on-surface-variant uppercase tracking-wider">Company Name <span class="text-error">*</span></label>
            <input type="text" name="company" placeholder="Company name" required class="input-field" />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-label-md text-on-surface-variant uppercase tracking-wider">Monthly Active Users</label>
            <select name="user_count" class="input-field">
              <option value="" disabled selected>Select MAU range</option>
              <option>Under 10,000</option>
              <option>10,000 – 50,000</option>
              <option>50,000 – 200,000</option>
              <option>200,000 – 1 Million</option>
              <option>1 Million+</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-label-md text-on-surface-variant uppercase tracking-wider">Current CRM / Email Tool</label>
            <select name="stack" class="input-field">
              <option value="" disabled selected>Which tool are you using?</option>
              <option>CleverTap</option>
              <option>MoEngage</option>
              <option>Salesforce</option>
              <option>Netcore</option>
              <option>HubSpot</option>
              <option>Mailchimp</option>
              <option>None / In-house</option>
              <option>Other</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-label-md text-on-surface-variant uppercase tracking-wider">Phone / WhatsApp</label>
            <input type="tel" name="phone" placeholder="+65 / +84 / +82" class="input-field" />
          </div>
          <div class="md:col-span-2 flex flex-col gap-2">
            <label class="text-label-md text-on-surface-variant uppercase tracking-wider">Biggest CRM Challenge</label>
            <textarea name="challenge" placeholder="Tell us what's holding you back — data silos, low personalisation, high churn, or something else..." rows="3" class="input-field resize-none"></textarea>
          </div>
          <div class="md:col-span-2 text-center mt-2">
            <button type="submit" class="btn-primary w-full md:w-auto px-12 py-4 text-base">
              Submit Audit Request
              <span class="material-symbols-outlined">arrow_forward</span>
            </button>
            <p class="mt-4 text-label-md text-on-surface-variant">Usually delivered within 2 business days. Zero spam — just value.</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>


<!-- ============================================================
     Results in Action — CRM Case Studies
     ============================================================ -->
<section class="py-16 bg-surface-off-white">
  <div class="section-container">
    <p class="eyebrow text-center mb-3">Results in Action</p>
    <h2 class="text-headline-md font-display text-on-surface text-center mb-10">CRM & Automation in Action</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {% for slug in ["fe-credit-mma-smarties", "vietjet-air-cdp", "sojo-hotel-crm"] %}
        {% set cs = case_studies | findBySlug(slug) %}
        {% if cs %}
          <a href="/case-studies/{{ cs.slug }}" class="group card overflow-hidden hover:shadow-[0_20px_60px_rgba(37,59,194,0.12)] hover:-translate-y-1 transition-all duration-300">
            <div class="relative aspect-video overflow-hidden bg-on-surface">
              <img src="{{ cs.video_thumbnail }}" alt="{{ cs.client }}" class="w-full h-full object-cover opacity-70 group-hover:opacity-90 group-hover:scale-105 transition-all duration-500" loading="lazy" />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 bg-action-yellow rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                  <span class="material-symbols-outlined text-on-secondary-fixed text-xl" style="font-variation-settings:'FILL' 1">play_arrow</span>
                </div>
              </div>
              {% if cs.award %}
                <div class="absolute top-3 left-3">
                  <span class="bg-action-yellow text-on-secondary-fixed text-[10px] font-bold px-2 py-0.5 rounded-full">{{ cs.award }}</span>
                </div>
              {% endif %}
              <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/80 to-transparent">
                <p class="text-white font-bold text-xs">{{ cs.client }}</p>
                <p class="text-white/60 text-[10px]">{{ cs.country }} · {{ cs.year }}</p>
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-display font-bold text-on-surface text-body-md mb-3 leading-snug group-hover:text-primary transition-colors">{{ cs.title }}</h3>
              <div class="flex flex-wrap gap-2 mb-4">
                {% for r in cs.results %}
                  <div class="bg-primary/8 rounded-lg px-2.5 py-1 text-center">
                    <span class="block text-primary font-display font-extrabold text-sm leading-none">{{ r.value }}</span>
                    <span class="text-[9px] text-on-surface-variant uppercase tracking-wider">{{ r.metric }}</span>
                  </div>
                {% endfor %}
              </div>
              <div class="flex items-center gap-1 text-primary font-bold text-xs group-hover:gap-2 transition-all">
                Read case study <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
