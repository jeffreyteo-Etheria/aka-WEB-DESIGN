<!-- ============================================================
     Case Study Card — used on /case-studies index grid
     Variables: study (object from case_studies.json)
     ============================================================ -->
<article class="group relative rounded-2xl overflow-hidden bg-inverse-surface">

  <!-- Cover image / video -->
  <div class="relative aspect-[4/3] overflow-hidden">
    {% if study.video_cover %}
      <video
        src="{{ study.video_cover }}"
        autoplay muted loop playsinline
        poster="{{ study.cover_image }}"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      ></video>
    {% else %}
      <img
        src="{{ study.cover_image }}"
        alt="{{ study.client }} case study cover"
        class="w-full h-full object-cover cs-img-animate"
        loading="lazy"
      />
    {% endif %}
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>

    <!-- Award badge -->
    {% if study.award %}
      <div class="absolute top-4 left-4 bg-action-yellow text-on-secondary-fixed text-label-md font-bold px-3 py-1 rounded-full">
        {{ study.award }}
      </div>
    {% endif %}
  </div>

  <!-- Card body -->
  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      {% if study.category_label %}
        <span class="inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full
          {% if study.category == 'social-influencer' %}bg-purple-500/15 text-purple-300
          {% elif study.category == 'programmatic-audio' %}bg-action-yellow/15 text-action-yellow
          {% elif study.category == 'crm-automation' %}bg-primary/20 text-primary-fixed
          {% else %}bg-white/10 text-inverse-on-surface/60{% endif %}">
          {{ study.category_label }}
        </span>
      {% endif %}
    </div>
    <p class="eyebrow mb-2">{{ study.industry }}</p>
    <h3 class="text-headline-sm font-display text-inverse-on-surface mb-3 leading-snug">
      {{ study.client }}: {{ study.title }}
    </h3>
    <p class="text-body-md text-inverse-on-surface/70 mb-5 line-clamp-2">
      {{ study.summary }}
    </p>

    <!-- Key results -->
    {% if study.results %}
      <div class="flex gap-4 mb-5">
        {% for result in study.results %}
          <div class="text-center">
            <span class="block text-headline-sm font-display font-bold text-action-yellow">{{ result.value }}</span>
            <span class="text-label-md text-inverse-on-surface/60">{{ result.metric }}</span>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <a
      href="/case-studies/{{ study.slug }}"
      class="btn-ghost text-inverse-primary"
    >
      Read case study
      <span class="material-symbols-outlined text-base">north_east</span>
    </a>
  </div>
</article>
