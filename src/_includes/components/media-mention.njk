<!-- ============================================================
     Media Mention Card — used in homepage "Global Recognition" section
     Variables: mention (object from content.json → media_mentions)
     ============================================================ -->
<div class="min-w-[280px] md:min-w-0 snap-center glass rounded-2xl p-6 space-y-4 flex-shrink-0 md:flex-shrink">
  <span class="eyebrow text-primary-fixed">{{ mention.publication }}</span>
  <p class="text-body-md text-inverse-on-surface italic leading-snug">
    "{{ mention.quote }}"
  </p>
  <a
    href="{{ mention.href }}"
    class="text-primary-fixed font-bold flex items-center gap-2 text-label-md hover:gap-3 transition-all"
    {% if mention.href != '#' %}target="_blank" rel="noopener noreferrer"{% endif %}
  >
    Read article
    <span class="material-symbols-outlined text-sm">north_east</span>
  </a>
</div>
