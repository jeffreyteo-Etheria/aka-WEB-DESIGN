<!-- ============================================================
     Solution Card — used on homepage and /solutions index
     Variables: solution (object from solutions.json)
     ============================================================ -->
<a
  href="{{ solution.href }}"
  class="card group flex flex-col gap-4 no-underline"
  aria-label="{{ solution.title }}"
>
  <!-- Icon -->
  <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-on-primary transition-all duration-200">
    <span class="material-symbols-outlined text-2xl">{{ solution.icon }}</span>
  </div>

  <!-- Text -->
  <div class="flex-1">
    <h3 class="text-headline-sm font-display text-on-surface mb-2 group-hover:text-primary transition-colors">
      {{ solution.short_title }}
    </h3>
    <p class="text-body-md text-on-surface-variant leading-relaxed">
      {{ solution.tagline }}
    </p>
  </div>

  <!-- Arrow -->
  <div class="flex items-center gap-1 text-label-md font-bold text-primary">
    Learn more
    <span class="material-symbols-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
  </div>
</a>
