<!-- Chat Lead Gen Widget -->
<div id="aka-chat-widget" class="fixed bottom-6 right-4 z-40 md:bottom-6">
  <!-- Chat form panel (hidden by default) -->
  <div id="aka-chat-panel" class="hidden mb-3 w-80 bg-white rounded-2xl shadow-2xl border border-outline-variant/20 overflow-hidden">
    <div class="bg-primary px-5 py-4 flex items-center justify-between">
      <div>
        <p class="text-white font-bold text-sm">Talk to AKA Digital</p>
        <p class="text-white/70 text-xs mt-0.5">We reply within 1 business day</p>
      </div>
      <button id="aka-chat-close" class="text-white/70 hover:text-white transition-colors" aria-label="Close">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form id="aka-chat-form" class="p-5 space-y-3" novalidate>
      <div>
        <label class="block text-label-md font-bold text-on-surface mb-1.5">Your Name</label>
        <input type="text" name="name" required placeholder="e.g. Nguyen Minh" class="w-full border border-outline-variant/40 rounded-xl px-3 py-2.5 text-body-md text-on-surface focus:outline-none focus:border-primary transition-colors" />
      </div>
      <div>
        <label class="block text-label-md font-bold text-on-surface mb-1.5">Work Email</label>
        <input type="email" name="email" required placeholder="you@company.com" class="w-full border border-outline-variant/40 rounded-xl px-3 py-2.5 text-body-md text-on-surface focus:outline-none focus:border-primary transition-colors" />
      </div>
      <div>
        <label class="block text-label-md font-bold text-on-surface mb-1.5">How can we help?</label>
        <select name="topic" class="w-full border border-outline-variant/40 rounded-xl px-3 py-2.5 text-body-md text-on-surface focus:outline-none focus:border-primary transition-colors bg-white">
          <option value="">Select a topic…</option>
          <option value="CRM & Marketing Automation">CRM & Marketing Automation</option>
          <option value="Digital & Programmatic Ads">Digital & Programmatic Ads</option>
          <option value="GEO / AI / SEO">GEO / AI / SEO</option>
          <option value="Social Media & KOL">Social Media & KOL</option>
          <option value="General Enquiry">General Enquiry</option>
        </select>
      </div>
      <button type="submit" class="w-full bg-primary text-white font-bold text-label-md py-3 rounded-xl hover:bg-primary/90 active:scale-95 transition-all">
        Send Message →
      </button>
      <p id="aka-chat-success" class="hidden text-center text-body-md text-primary font-bold pt-1">Thanks! We'll be in touch soon.</p>
    </form>
  </div>

  <!-- FAB trigger button -->
  <button id="aka-chat-fab" class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center shadow-xl hover:scale-110 active:scale-95 transition-all" aria-label="Chat with AKA Digital">
    <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
  </button>
</div>

<script>
(function(){
  var fab   = document.getElementById('aka-chat-fab');
  var panel = document.getElementById('aka-chat-panel');
  var close = document.getElementById('aka-chat-close');
  var form  = document.getElementById('aka-chat-form');
  var succ  = document.getElementById('aka-chat-success');
  if (!fab) return;
  fab.addEventListener('click', function(){ panel.classList.toggle('hidden'); });
  close.addEventListener('click', function(){ panel.classList.add('hidden'); });
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var d = new FormData(form);
    var name  = d.get('name') || '';
    var email = d.get('email') || '';
    var topic = d.get('topic') || 'General Enquiry';
    if (!name || !email) return;
    var subject = encodeURIComponent('Website Enquiry: ' + topic);
    var body    = encodeURIComponent('Name: ' + name + '\nEmail: ' + email + '\nTopic: ' + topic);
    window.location.href = 'mailto:jeffrey.teo@akadigital.net?subject=' + subject + '&body=' + body;
    succ.classList.remove('hidden');
    form.querySelector('button[type=submit]').classList.add('hidden');
  });
})();
</script>

