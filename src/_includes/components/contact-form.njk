<!-- ============================================================
     Lead Gen / Contact Form
     1. Email delivery  : FormSubmit.co → jeffrey.teo@akadigital.net
     2. CRM bridge      : Google Sheets webhook (Phase 2)
        → Set WEBHOOK_URL below to your Google Apps Script URL.
        → In Make.com, watch the "New Lead" rows to trigger sequences:
            Status = "New Lead"              → immediate welcome email
            Status = "No Response - 3 Days"  → 3-day follow-up (set by Make.com)
            Status = "10-Day Follow-Up"       → 10-day nurture (set by Make.com)
            Status = "Retargeting - 30 Days"  → retargeting reminder
     ============================================================ -->
<form
  id="contact-form"
  action="https://formsubmit.co/jeffrey.teo@akadigital.net"
  method="POST"
  class="space-y-5"
>
  <!-- FormSubmit config -->
  <input type="hidden" name="_subject" value="New Enquiry — AKA Digital Website">
  <input type="hidden" name="_template" value="table">
  <input type="hidden" name="_captcha" value="false">
  <input type="hidden" name="_next" value="https://akadigital.net/contact/?submitted=true">

  <div>
    <label for="form-name" class="block text-label-md text-on-surface-variant mb-1" data-i18n="form.name">
      Your Name
    </label>
    <input
      id="form-name"
      name="name"
      type="text"
      required
      autocomplete="name"
      class="input-field"
      placeholder="e.g. John Smith"
    />
  </div>

  <div>
    <label for="form-company" class="block text-label-md text-on-surface-variant mb-1" data-i18n="form.company">
      Company
    </label>
    <input
      id="form-company"
      name="company"
      type="text"
      autocomplete="organization"
      class="input-field"
      placeholder="Your company name"
    />
  </div>

  <div>
    <label for="form-email" class="block text-label-md text-on-surface-variant mb-1" data-i18n="form.email">
      Email Address
    </label>
    <input
      id="form-email"
      name="email"
      type="email"
      required
      autocomplete="email"
      class="input-field"
      placeholder="you@company.com"
    />
  </div>

  <div>
    <label for="form-phone" class="block text-label-md text-on-surface-variant mb-1" data-i18n="form.phone">
      Phone (optional)
    </label>
    <input
      id="form-phone"
      name="phone"
      type="tel"
      autocomplete="tel"
      class="input-field"
      placeholder="+65 / +84 / +66"
    />
  </div>

  <div>
    <label for="form-service" class="block text-label-md text-on-surface-variant mb-1" data-i18n="form.service">
      Service Interest
    </label>
    <select id="form-service" name="service" class="input-field text-on-surface-variant">
      <option value="">— Select a service —</option>
      <option value="crm-automation">CRM &amp; Marketing Automation</option>
      <option value="digital-programmatic">Digital Marketing &amp; Programmatic</option>
      <option value="geo-ai-seo">GEO / AI / SGO / AEO / SEO</option>
      <option value="social-media">Social Media Marketing</option>
      <option value="consulting">Strategic Consulting</option>
      <option value="other">Other / Not sure yet</option>
    </select>
  </div>

  <div>
    <label for="form-message" class="block text-label-md text-on-surface-variant mb-1" data-i18n="form.message">
      Message (optional)
    </label>
    <textarea
      id="form-message"
      name="message"
      rows="4"
      class="input-field resize-none"
      placeholder="Tell us about your goals or challenges..."
    ></textarea>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    id="form-submit"
    class="btn-primary w-full"
  >
    <span id="form-submit-text" data-i18n="form.submit">Send Enquiry</span>
  </button>

  <!-- Status messages -->
  <p id="form-success" class="hidden text-body-md text-center text-primary font-bold py-2">
    ✓ Message sent! We'll be in touch within 1 business day.
  </p>
  <p id="form-error" class="hidden text-body-md text-center text-error font-bold py-2">
    Something went wrong. Please email us directly at jeffrey.teo@akadigital.net
  </p>
</form>

<!-- ── Phase 2: Google Sheets CRM webhook ───────────────────────────────
     Replace REPLACE_WITH_YOUR_APPS_SCRIPT_URL with your Google Apps Script
     web app URL. See setup guide: /admin → CRM Setup.
     ─────────────────────────────────────────────────────────────────── -->
<script>
(function() {
  var WEBHOOK_URL = '{{ settings.google_sheets_webhook }}';

  var form = document.getElementById('contact-form');
  if (!form || !WEBHOOK_URL || WEBHOOK_URL.indexOf('REPLACE') !== -1) return;

  form.addEventListener('submit', function(e) {
    /* Phase 3: CRM payload structure for Make.com automation sequences */
    var payload = {
      form_type:   'lead',
      source_page: window.location.pathname,
      market:      'SG/SEA',
      assigned_to: 'jeffrey.teo@akadigital.net',
      name:        (document.getElementById('form-name')    || {}).value || '',
      company:     (document.getElementById('form-company') || {}).value || '',
      email:       (document.getElementById('form-email')   || {}).value || '',
      phone:       (document.getElementById('form-phone')   || {}).value || '',
      service:     (document.getElementById('form-service') || {}).value || '',
      message:     (document.getElementById('form-message') || {}).value || '',
      /*
       * Make.com Sequence Triggers (set up in Google Sheets + Make.com):
       * ─────────────────────────────────────────────────────────────────
       * Trigger 1 — "New Lead" (immediate)
       *   → Send personalised welcome email via Gmail / Mailchimp
       *   → Add to CRM contact list
       *
       * Trigger 2 — "No Response - 3 Days" (set by Make.com after 72h)
       *   → Watch: if lead_status = "New Lead" AND no reply after 3 days
       *   → Action: send follow-up email + WhatsApp message
       *
       * Trigger 3 — "10-Day Follow-Up" (set by Make.com after 10 days)
       *   → Watch: if lead_status still "New Lead" after 10 days
       *   → Action: send case study + consultation offer
       *
       * Trigger 4 — "Retargeting - 30 Days" (set by Make.com after 30 days)
       *   → Watch: if lead_status = "No Response" after 30 days
       *   → Action: add to Facebook Custom Audience retargeting list
       */
    };

    fetch(WEBHOOK_URL, {
      method: 'POST',
      mode:   'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    }).catch(function() { /* silent fail — FormSubmit.co handles primary delivery */ });
  });
})();
</script>
