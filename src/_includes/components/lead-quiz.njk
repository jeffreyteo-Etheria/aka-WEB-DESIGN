<!-- ============================================================
     AKA Digital — 4-Step Solution Matcher
     Step 1 → Choose core solution
     Step 2 → Pain points (solution-specific)
     Step 3 → Budget range
     Step 4 → Contact form (Name / Brand / Company / Email / Phone)
     ============================================================ -->
<div class="bg-white rounded-2xl border border-outline-variant/20 shadow-[0_4px_24px_rgba(0,0,0,0.06)] overflow-hidden" id="lead-quiz">

  <!-- Progress bar -->
  <div class="h-1.5 bg-surface-container">
    <div id="quiz-progress" class="h-1.5 bg-gradient-to-r from-primary to-action-yellow transition-all duration-500 ease-out" style="width:0%"></div>
  </div>

  <!-- Step indicator -->
  <div class="px-6 pt-4 pb-0 flex items-center justify-between">
    <span id="quiz-step-label" class="text-label-md text-on-surface-variant uppercase tracking-widest">Step 1 of 4</span>
    <div class="flex gap-2">
      <span class="quiz-dot w-2 h-2 rounded-full bg-primary transition-colors duration-300" data-step="1"></span>
      <span class="quiz-dot w-2 h-2 rounded-full bg-outline-variant transition-colors duration-300" data-step="2"></span>
      <span class="quiz-dot w-2 h-2 rounded-full bg-outline-variant transition-colors duration-300" data-step="3"></span>
      <span class="quiz-dot w-2 h-2 rounded-full bg-outline-variant transition-colors duration-300" data-step="4"></span>
    </div>
  </div>

  <!-- ─── STEP 1: Choose Core Solution ─── -->
  <div id="quiz-step-1" class="quiz-step px-6 py-5">
    <p class="text-label-md text-primary font-bold uppercase tracking-wider mb-1">Step 1 of 4</p>
    <h3 class="text-headline-sm font-display text-on-surface mb-1">Which solution area matches your goals?</h3>
    <p class="text-body-md text-on-surface-variant mb-5">Choose the pillar most relevant to your business right now.</p>
    <div class="space-y-2.5">

      <button class="quiz-option w-full flex items-start gap-4 p-4 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-left transition-all duration-200 group" data-solution="crm-automation">
        <div class="w-11 h-11 rounded-xl bg-primary/10 group-hover:bg-primary flex items-center justify-center shrink-0 transition-colors duration-200 mt-0.5">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-on-primary transition-colors" style="font-variation-settings:'FILL' 1">autorenew</span>
        </div>
        <div class="flex-1 min-w-0">
          <span class="font-display font-bold text-on-surface block">CRM & Marketing Automation</span>
          <span class="text-label-md text-on-surface-variant block mt-0.5">Unify data · automate journeys · personalise at scale</span>
        </div>
        <span class="material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors text-xl mt-0.5 shrink-0">chevron_right</span>
      </button>

      <button class="quiz-option w-full flex items-start gap-4 p-4 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-left transition-all duration-200 group" data-solution="digital-programmatic">
        <div class="w-11 h-11 rounded-xl bg-primary/10 group-hover:bg-primary flex items-center justify-center shrink-0 transition-colors duration-200 mt-0.5">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-on-primary transition-colors" style="font-variation-settings:'FILL' 1">ads_click</span>
        </div>
        <div class="flex-1 min-w-0">
          <span class="font-display font-bold text-on-surface block">Digital Marketing & Programmatic</span>
          <span class="text-label-md text-on-surface-variant block mt-0.5">Precision-targeted ads · multi-market reach · ROAS</span>
        </div>
        <span class="material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors text-xl mt-0.5 shrink-0">chevron_right</span>
      </button>

      <button class="quiz-option w-full flex items-start gap-4 p-4 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-left transition-all duration-200 group" data-solution="geo-ai-seo">
        <div class="w-11 h-11 rounded-xl bg-primary/10 group-hover:bg-primary flex items-center justify-center shrink-0 transition-colors duration-200 mt-0.5">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-on-primary transition-colors" style="font-variation-settings:'FILL' 1">travel_explore</span>
        </div>
        <div class="flex-1 min-w-0">
          <span class="font-display font-bold text-on-surface block">GEO / AI / SEO</span>
          <span class="text-label-md text-on-surface-variant block mt-0.5">AI search visibility · organic growth · content strategy</span>
        </div>
        <span class="material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors text-xl mt-0.5 shrink-0">chevron_right</span>
      </button>

      <button class="quiz-option w-full flex items-start gap-4 p-4 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-left transition-all duration-200 group" data-solution="social-media">
        <div class="w-11 h-11 rounded-xl bg-primary/10 group-hover:bg-primary flex items-center justify-center shrink-0 transition-colors duration-200 mt-0.5">
          <span class="material-symbols-outlined text-xl text-primary group-hover:text-on-primary transition-colors" style="font-variation-settings:'FILL' 1">groups</span>
        </div>
        <div class="flex-1 min-w-0">
          <span class="font-display font-bold text-on-surface block">Social Media & KOL Marketing</span>
          <span class="text-label-md text-on-surface-variant block mt-0.5">Influencer strategy · KOL ROI · platform growth</span>
        </div>
        <span class="material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors text-xl mt-0.5 shrink-0">chevron_right</span>
      </button>

    </div>
  </div>

  <!-- ─── STEP 2: Pain Points (dynamic per solution) ─── -->
  <div id="quiz-step-2" class="quiz-step hidden px-6 py-5">
    <button class="quiz-back flex items-center gap-1 text-label-md text-on-surface-variant hover:text-primary mb-4 transition-colors" data-goto="1">
      <span class="material-symbols-outlined text-base">arrow_back</span> Back
    </button>
    <!-- Solution context banner -->
    <div id="quiz-solution-banner" class="flex items-center gap-3 mb-4 p-3 bg-primary/6 rounded-xl border border-primary/15">
      <span id="quiz-banner-icon" class="material-symbols-outlined text-primary text-xl" style="font-variation-settings:'FILL' 1">autorenew</span>
      <span id="quiz-banner-label" class="text-label-md font-bold text-primary uppercase tracking-wider">CRM & Marketing Automation</span>
    </div>
    <p class="text-label-md text-primary font-bold uppercase tracking-wider mb-1">Step 2 of 4</p>
    <h3 class="text-headline-sm font-display text-on-surface mb-1">What's your biggest challenge right now?</h3>
    <p class="text-body-md text-on-surface-variant mb-5">Select the problem that's costing you the most.</p>
    <div id="quiz-pain-points" class="space-y-2.5">
      <!-- Populated by JS based on Step 1 selection -->
    </div>
  </div>

  <!-- ─── STEP 3: Budget Range ─── -->
  <div id="quiz-step-3" class="quiz-step hidden px-6 py-5">
    <button class="quiz-back flex items-center gap-1 text-label-md text-on-surface-variant hover:text-primary mb-4 transition-colors" data-goto="2">
      <span class="material-symbols-outlined text-base">arrow_back</span> Back
    </button>
    <p class="text-label-md text-primary font-bold uppercase tracking-wider mb-1">Step 3 of 4</p>
    <h3 class="text-headline-sm font-display text-on-surface mb-1">What's your typical monthly marketing budget?</h3>
    <p class="text-body-md text-on-surface-variant mb-5">This helps us recommend the right package and team size for you.</p>
    <div class="grid grid-cols-2 gap-3">

      <button class="quiz-option flex flex-col items-center justify-center gap-2 p-5 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-center transition-all duration-200 group" data-key="under10k" data-label="Under $10,000/mo">
        <span class="material-symbols-outlined text-2xl text-on-surface-variant group-hover:text-primary transition-colors">attach_money</span>
        <span class="font-display font-bold text-on-surface">Under $10K</span>
        <span class="text-label-md text-on-surface-variant">per month</span>
      </button>

      <button class="quiz-option flex flex-col items-center justify-center gap-2 p-5 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-center transition-all duration-200 group" data-key="10to30k" data-label="$10,000 – $30,000/mo">
        <span class="material-symbols-outlined text-2xl text-on-surface-variant group-hover:text-primary transition-colors">monetization_on</span>
        <span class="font-display font-bold text-on-surface">$10K – $30K</span>
        <span class="text-label-md text-on-surface-variant">per month</span>
      </button>

      <button class="quiz-option flex flex-col items-center justify-center gap-2 p-5 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-center transition-all duration-200 group" data-key="30to100k" data-label="$30,000 – $100,000/mo">
        <span class="material-symbols-outlined text-2xl text-on-surface-variant group-hover:text-primary transition-colors">account_balance</span>
        <span class="font-display font-bold text-on-surface">$30K – $100K</span>
        <span class="text-label-md text-on-surface-variant">per month</span>
      </button>

      <button class="quiz-option flex flex-col items-center justify-center gap-2 p-5 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-center transition-all duration-200 group" data-key="100kplus" data-label="$100,000+/mo">
        <span class="material-symbols-outlined text-2xl text-on-surface-variant group-hover:text-primary transition-colors">rocket_launch</span>
        <span class="font-display font-bold text-on-surface">$100K+</span>
        <span class="text-label-md text-on-surface-variant">per month</span>
      </button>

    </div>
  </div>

  <!-- ─── STEP 4: Lead Capture ─── -->
  <div id="quiz-step-4" class="quiz-step hidden px-6 py-5">
    <button class="quiz-back flex items-center gap-1 text-label-md text-on-surface-variant hover:text-primary mb-4 transition-colors" data-goto="3">
      <span class="material-symbols-outlined text-base">arrow_back</span> Back
    </button>

    <!-- Matched solution teaser -->
    <div class="mb-5 p-4 rounded-xl border border-primary/20 bg-gradient-to-br from-primary/6 to-primary/2">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center shrink-0">
          <span id="quiz-preview-icon" class="material-symbols-outlined text-on-primary text-xl" style="font-variation-settings:'FILL' 1">auto_awesome</span>
        </div>
        <div>
          <p class="text-label-md text-primary font-bold uppercase tracking-wider">Your Matched Solution</p>
          <p id="quiz-preview-title" class="font-display font-bold text-on-surface text-body-md">CRM & Marketing Automation</p>
        </div>
      </div>
    </div>

    <p class="text-label-md text-primary font-bold uppercase tracking-wider mb-1">Step 4 of 4</p>
    <h3 class="text-headline-sm font-display text-on-surface mb-1">Almost there — who should we reach out to?</h3>
    <p class="text-body-md text-on-surface-variant mb-5">We'll send your custom solution plan and a consultation invite within 1 business day.</p>

    <form id="quiz-form" class="space-y-4" novalidate>
      <input type="hidden" id="quiz-h-solution" name="solution" />
      <input type="hidden" id="quiz-h-pain" name="pain_point" />
      <input type="hidden" id="quiz-h-budget" name="budget" />

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-label-md text-on-surface-variant mb-1.5">Full Name <span class="text-error">*</span></label>
          <input id="quiz-name" name="name" type="text" required autocomplete="name"
            class="input-field" placeholder="Your name" />
        </div>
        <div>
          <label class="block text-label-md text-on-surface-variant mb-1.5">Brand Name</label>
          <input id="quiz-brand" name="brand" type="text"
            class="input-field" placeholder="Brand / product name" />
        </div>
      </div>

      <div>
        <label class="block text-label-md text-on-surface-variant mb-1.5">Company <span class="text-error">*</span></label>
        <input id="quiz-company" name="company" type="text" required autocomplete="organization"
          class="input-field" placeholder="Company name" />
      </div>

      <div>
        <label class="block text-label-md text-on-surface-variant mb-1.5">Work Email <span class="text-error">*</span></label>
        <input id="quiz-email" name="email" type="email" required autocomplete="email"
          class="input-field" placeholder="you@company.com" />
      </div>

      <div>
        <label class="block text-label-md text-on-surface-variant mb-1.5">Phone / WhatsApp</label>
        <input id="quiz-phone" name="phone" type="tel" autocomplete="tel"
          class="input-field" placeholder="+65 / +84 / +82" />
      </div>

      <button type="submit" id="quiz-submit" class="btn-primary w-full">
        <span id="quiz-submit-text">{{ settings.cta.solution_plan_text }}</span>
        <span id="quiz-submit-spinner" class="hidden material-symbols-outlined animate-spin text-lg">progress_activity</span>
      </button>

      <p class="text-label-md text-on-surface-variant text-center">
        No commitment required. Response within 1 business day.
      </p>

      <p id="quiz-error" class="hidden text-body-md text-center text-error font-bold py-2">
        Something went wrong. Please email us at
        <a href="mailto:jeffrey.teo@akadigital.net" class="underline">jeffrey.teo@akadigital.net</a>
      </p>
    </form>
  </div>

  <!-- ─── STEP 5: Result ─── -->
  <div id="quiz-step-5" class="quiz-step hidden">
    <div class="relative h-32 overflow-hidden">
      <img id="quiz-result-img" src="/images/activities/MartechSummit2025/MartechSummit2025_0001.jpeg"
        alt="Your matched solution" class="w-full h-full object-cover object-top" />
      <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-primary/40 to-transparent"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="material-symbols-outlined text-5xl text-white" style="font-variation-settings:'FILL' 1">check_circle</span>
      </div>
    </div>
    <div class="px-6 py-6">
      <div class="text-center mb-5">
        <span class="inline-block bg-action-yellow text-on-surface text-label-md font-bold px-4 py-1.5 rounded-full mb-3 uppercase tracking-wider">
          Plan Ready
        </span>
        <h3 id="quiz-result-title" class="text-headline-sm font-display text-on-surface mb-1">CRM & Marketing Automation</h3>
        <p id="quiz-result-tagline" class="text-label-md font-bold text-primary uppercase tracking-wider mb-3">Automate. Personalise. Convert.</p>
        <p id="quiz-result-desc" class="text-body-md text-on-surface-variant leading-relaxed"></p>
      </div>
      <div class="space-y-3">
        <a id="quiz-result-cta" href="/solutions/crm-automation" class="btn-primary w-full flex justify-center">
          Explore This Solution <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        <a href="/contact" class="btn-secondary w-full flex justify-center">Book a Free Consultation</a>
      </div>
      <p class="text-label-md text-on-surface-variant text-center mt-4">
        ✓ Our team will reach out within 1 business day.
      </p>
    </div>
  </div>

</div>

<script>
(function () {
  /* ── Solution definitions ── */
  var SOLUTIONS = {
    "crm-automation": {
      title: "CRM & Marketing Automation",
      tagline: "Automate. Personalise. Convert.",
      icon: "autorenew",
      desc: "Build intelligent customer journeys that engage at every touchpoint. From CDP setup to lifecycle automation, we turn your data into measurable revenue.",
      href: "/solutions/crm-automation",
      img: "/images/activities/MartechSummit2025/MartechSummit2025_0003.jpeg",
      painPoints: [
        { key: "data_silos", label: "Customer data is scattered — no single view of the customer" },
        { key: "no_personalisation", label: "Campaigns aren't personalised — same message to everyone" },
        { key: "high_churn", label: "High churn rate and poor customer retention" },
        { key: "manual_ops", label: "Manual processes slowing down marketing operations" },
        { key: "no_attribution", label: "Can't track or prove campaign ROI end-to-end" }
      ]
    },
    "digital-programmatic": {
      title: "Digital Marketing & Programmatic",
      tagline: "Precision targeting. Measurable reach.",
      icon: "ads_click",
      desc: "Reach the right audience across SEA markets with full-funnel programmatic, paid social, and DOOH — with real-time optimisation and transparent reporting.",
      href: "/solutions/digital-programmatic",
      img: "/images/activities/MartechSummit2025/MartechSummit2025_0007.jpeg",
      painPoints: [
        { key: "poor_roas", label: "High cost-per-lead and poor return on ad spend" },
        { key: "wrong_audience", label: "Ads reaching the wrong audience — wasted impressions" },
        { key: "google_meta_only", label: "Stuck on Google/Meta only — limited multi-channel reach" },
        { key: "no_attribution", label: "No visibility on which channels are actually converting" },
        { key: "market_expansion", label: "Need to expand into new SEA markets quickly and efficiently" }
      ]
    },
    "geo-ai-seo": {
      title: "GEO / AI / SEO",
      tagline: "Dominate the future of search.",
      icon: "travel_explore",
      desc: "Go beyond traditional SEO. Get cited in AI-generated answers, appear in voice and conversational search, and stay visible as search behaviour evolves.",
      href: "/solutions/geo-ai-seo",
      img: "/images/activities/MartechSummit2025/MartechSummit2025_0012.jpeg",
      painPoints: [
        { key: "ai_invisible", label: "Brand not showing up in AI-generated search answers (ChatGPT, Gemini, Perplexity)" },
        { key: "traffic_drop", label: "Organic traffic declining as users shift to AI tools" },
        { key: "low_rankings", label: "Poor organic search rankings on competitive keywords" },
        { key: "content_gap", label: "Content not structured for LLM indexability or E-E-A-T signals" },
        { key: "competitor_dominance", label: "Competitors dominating search — losing mindshare to them" }
      ]
    },
    "social-media": {
      title: "Social Media & KOL Marketing",
      tagline: "Build reach. Drive real results.",
      icon: "groups",
      desc: "Build communities, grow brand awareness, and drive real conversions through KOL partnerships, content strategy, and platform-specific social media management.",
      href: "/solutions/social-media",
      img: "/images/activities/MartechSummit2025/MartechSummit2025_0020.jpeg",
      painPoints: [
        { key: "low_reach", label: "Organic reach declining — content not getting seen" },
        { key: "kol_roi", label: "KOL campaigns not converting to sales or measurable results" },
        { key: "finding_kols", label: "Struggling to find and properly vet the right influencers" },
        { key: "inconsistent_content", label: "Inconsistent brand messaging and content quality across platforms" },
        { key: "no_commerce_link", label: "Can't link social content to actual product sales or conversions" }
      ]
    }
  };

  var state = { step: 1, solution: null, pain: null, budget: null };

  /* ── Progress bar & dots ── */
  function updateProgress(step) {
    document.getElementById('quiz-progress').style.width = ((step - 1) / 4 * 100) + '%';
    document.getElementById('quiz-step-label').textContent = step <= 4 ? 'Step ' + step + ' of 4' : 'Complete';
    document.querySelectorAll('.quiz-dot').forEach(function (dot, i) {
      dot.className = 'quiz-dot w-2 h-2 rounded-full transition-colors duration-300 ' + (i < step ? 'bg-primary' : 'bg-outline-variant');
    });
  }

  /* ── Animated step transition ── */
  function showStep(n) {
    document.querySelectorAll('.quiz-step').forEach(function (el) {
      el.classList.add('hidden');
      el.style.opacity = '';
      el.style.transform = '';
      el.style.transition = '';
    });
    var target = document.getElementById('quiz-step-' + n);
    if (!target) return;
    target.classList.remove('hidden');
    target.style.opacity = '0';
    target.style.transform = 'translateX(18px)';
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        target.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
        target.style.opacity = '1';
        target.style.transform = 'translateX(0)';
      });
    });
    updateProgress(n);
    state.step = n;
  }

  /* ── Render pain points for chosen solution ── */
  function renderPainPoints(solutionKey) {
    var sol = SOLUTIONS[solutionKey];
    if (!sol) return;
    /* Update banner */
    document.getElementById('quiz-banner-icon').textContent = sol.icon;
    document.getElementById('quiz-banner-label').textContent = sol.title;
    /* Render buttons */
    var container = document.getElementById('quiz-pain-points');
    container.innerHTML = sol.painPoints.map(function (pp) {
      return '<button class="quiz-option w-full flex items-start gap-4 p-4 rounded-xl border-2 border-outline-variant/40 hover:border-primary hover:bg-primary/5 text-left transition-all duration-200 group" data-key="' + pp.key + '" data-label="' + pp.label.replace(/"/g, '&quot;') + '">' +
        '<div class="w-5 h-5 rounded-full border-2 border-outline-variant group-hover:border-primary flex items-center justify-center shrink-0 mt-0.5 transition-colors duration-200">' +
          '<div class="w-2.5 h-2.5 rounded-full bg-primary scale-0 group-hover:scale-100 transition-transform duration-200"></div>' +
        '</div>' +
        '<span class="text-body-md text-on-surface flex-1">' + pp.label + '</span>' +
        '<span class="material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors text-xl shrink-0">chevron_right</span>' +
      '</button>';
    }).join('');
    /* Wire new buttons */
    container.querySelectorAll('.quiz-option').forEach(function (btn) {
      btn.addEventListener('click', function () {
        state.pain = btn.dataset.key;
        document.getElementById('quiz-h-pain').value = btn.dataset.label || btn.dataset.key;
        showStep(3);
      });
    });
  }

  /* ── Populate result step ── */
  function applyResult() {
    var sol = SOLUTIONS[state.solution] || SOLUTIONS['crm-automation'];
    document.getElementById('quiz-preview-title').textContent = sol.title;
    document.getElementById('quiz-preview-icon').textContent = sol.icon;
    document.getElementById('quiz-result-title').textContent = sol.title;
    document.getElementById('quiz-result-tagline').textContent = sol.tagline;
    document.getElementById('quiz-result-desc').textContent = sol.desc;
    document.getElementById('quiz-result-img').src = sol.img;
    document.getElementById('quiz-result-cta').href = sol.href;
  }

  /* ── Step 1: Solution selection ── */
  document.querySelectorAll('#quiz-step-1 .quiz-option').forEach(function (btn) {
    btn.addEventListener('click', function () {
      state.solution = btn.dataset.solution;
      document.getElementById('quiz-h-solution').value = state.solution;
      renderPainPoints(state.solution);
      applyResult();
      showStep(2);
    });
  });

  /* ── Step 3: Budget selection ── */
  document.querySelectorAll('#quiz-step-3 .quiz-option').forEach(function (btn) {
    btn.addEventListener('click', function () {
      state.budget = btn.dataset.key;
      document.getElementById('quiz-h-budget').value = btn.dataset.label || btn.dataset.key;
      showStep(4);
    });
  });

  /* ── Back buttons ── */
  document.querySelectorAll('.quiz-back').forEach(function (btn) {
    btn.addEventListener('click', function () {
      showStep(parseInt(btn.dataset.goto, 10));
    });
  });

  /* ── Form submit → mailto routing ── */
  document.getElementById('quiz-form').addEventListener('submit', function (e) {
    e.preventDefault();
    var name = document.getElementById('quiz-name');
    var company = document.getElementById('quiz-company');
    var email = document.getElementById('quiz-email');
    var valid = true;
    [name, company, email].forEach(function (el) {
      if (!el.value.trim()) { el.style.outline = '2px solid #ba1a1a'; valid = false; }
      else el.style.outline = '';
    });
    if (!valid) return;

    var submitBtn = document.getElementById('quiz-submit');
    var submitText = document.getElementById('quiz-submit-text');
    var spinner = document.getElementById('quiz-submit-spinner');
    submitBtn.disabled = true;
    submitText.classList.add('hidden');
    spinner.classList.remove('hidden');

    var sol = SOLUTIONS[state.solution] || SOLUTIONS['crm-automation'];
    var brand = document.getElementById('quiz-brand').value;
    var phone = document.getElementById('quiz-phone').value;
    var pain = document.getElementById('quiz-h-pain').value || '—';
    var budget = document.getElementById('quiz-h-budget').value || '—';

    /* CRM bridge: Google Sheets webhook (same pattern as contact-form.njk / careers.njk) */
    var payload = {
      form_type:   'lead',
      source_page: window.location.pathname,
      market:      'SG/SEA',
      assigned_to: 'jeffrey.teo@akadigital.net',
      solution:    sol.title,
      pain_point:  pain,
      budget:      budget,
      name:        name.value,
      brand:       brand,
      company:     company.value,
      email:       email.value,
      phone:       phone
    };
    var webhookUrl = '{{ cms_settings.webhook_url }}';
    if (webhookUrl && webhookUrl.indexOf('REPLACE') === -1) {
      fetch(webhookUrl, {
        method: 'POST',
        mode:   'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body:   JSON.stringify(payload)
      }).catch(function () {});
    } else {
      var body = [
        'Solution: ' + sol.title,
        'Challenge: ' + pain,
        'Budget: ' + budget,
        '',
        'Name: ' + name.value,
        'Brand: ' + brand,
        'Company: ' + company.value,
        'Email: ' + email.value,
        'Phone: ' + phone
      ].join('\n');
      var subject = 'Solution Match: ' + sol.title + ' — ' + name.value;
      window.location.href = 'mailto:jeffrey.teo@akadigital.net?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
    }

    /* Show result screen */
    setTimeout(function () {
      document.getElementById('quiz-progress').style.width = '100%';
      document.getElementById('quiz-step-label').textContent = 'Complete';
      showStep(5);
    }, 400);
  });
})();
</script>
