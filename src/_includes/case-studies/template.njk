{% set study = case_studies | findBySlug(studySlug) %}

{% if not study or (study.status != 'published' and not isPreview) %}
  <div class="section-container py-32 text-center">
    <h1 class="text-headline-md font-display text-on-surface">Case study not found</h1>
    <a href="/case-studies" class="btn-primary mt-8 inline-flex">Back to case studies</a>
  </div>
{% else %}

<!-- ── JSON-LD Schema ── -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ study.client }}: {{ study.title }}",
  "description": "{{ study.summary }}",
  "author": { "@type": "Organization", "name": "AKA Digital" },
  "publisher": { "@type": "Organization", "name": "AKA Digital", "url": "{{ settings.siteUrl }}" },
  "datePublished": "{{ study.year }}-01-01",
  "image": "{{ settings.siteUrl }}{{ study.cover_image }}"
}
</script>

<!-- ── Breadcrumb ── -->
<nav class="bg-surface-off-white border-b border-outline-variant/10" aria-label="Breadcrumb">
  <div class="section-container py-3">
    <ol class="flex items-center gap-2 text-label-md text-on-surface-variant flex-wrap">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li><span class="material-symbols-outlined text-sm opacity-50">chevron_right</span></li>
      <li><a href="/case-studies" class="hover:text-primary transition-colors">Case Studies</a></li>
      <li><span class="material-symbols-outlined text-sm opacity-50">chevron_right</span></li>
      <li class="text-on-surface font-bold">{{ study.client }}</li>
    </ol>
  </div>
</nav>

<!-- ── Hero ── -->
<section class="relative min-h-[65vh] flex items-end py-20 bg-on-surface overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src="{{ study.cover_image }}" alt="{{ study.client }}"
      class="w-full h-full object-cover opacity-25" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-on-surface via-on-surface/85 to-on-surface/50"></div>
  </div>
  <div class="relative z-10 section-container">
    <a href="/case-studies" class="inline-flex items-center gap-1 text-label-md text-inverse-on-surface/60 hover:text-inverse-on-surface transition-colors mb-8">
      <span class="material-symbols-outlined text-base">arrow_back</span> All Case Studies
    </a>
    <div class="max-w-3xl">
      {% if study.award %}
        <div class="inline-flex items-center gap-2 bg-action-yellow text-on-surface px-4 py-2 rounded-full text-label-md font-bold uppercase tracking-wider mb-5">
          <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1">emoji_events</span>
          {{ study.award }}
        </div>
      {% endif %}
      <p class="eyebrow text-primary-fixed mb-3">{{ study.industry }} · {{ study.country }} · {{ study.year }}</p>
      <h1 class="text-headline-lg-mobile md:text-headline-lg font-display font-bold text-inverse-on-surface mb-5 text-balance leading-tight">
        {{ study.client }}: {{ study.title }}
      </h1>
      <p class="text-body-lg text-inverse-on-surface/75 max-w-2xl leading-relaxed">{{ study.summary }}</p>

      <!-- Key results inline -->
      {% if study.results %}
        <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t border-white/10">
          {% for r in study.results %}
            <div>
              <span class="block font-display font-extrabold text-headline-md text-action-yellow leading-none mb-1 notranslate" translate="no">{{ r.value }}</span>
              <span class="text-label-md text-inverse-on-surface/70 uppercase tracking-wider">{{ r.metric }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- ── Video Section — YouTube or Wix ── -->
{% if study.video_youtube or study.video_wix_url %}
<section class="py-16 md:py-20 bg-on-surface">
  <div class="section-container">
    <p class="eyebrow text-primary-fixed text-center mb-8">Watch the Case Study</p>
    <div class="max-w-4xl mx-auto">
      <div class="relative w-full rounded-2xl overflow-hidden shadow-[0_32px_100px_rgba(0,0,0,0.4)]"
           style="padding-top:56.25%">
        {% if study.video_youtube %}
          <iframe
            class="absolute inset-0 w-full h-full"
            src="https://www.youtube.com/embed/{{ study.video_youtube }}?rel=0&modestbranding=1&color=white"
            title="{{ study.client }} — AKA Digital Case Study"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading="lazy">
          </iframe>
        {% elif study.video_wix_url %}
          <iframe
            class="absolute inset-0 w-full h-full"
            src="{{ study.video_wix_url }}"
            title="{{ study.client }} — AKA Digital Case Study"
            frameborder="0"
            allow="autoplay; fullscreen"
            allowfullscreen
            loading="lazy">
          </iframe>
        {% endif %}
      </div>
    </div>
  </div>
</section>
{% endif %}

<!-- ── Results metrics ── -->
{% if study.results %}
<section class="py-14 bg-primary text-on-primary">
  <div class="section-container">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      {% for r in study.results %}
        <div>
          <span class="block font-display font-extrabold text-[52px] md:text-[64px] leading-none text-action-yellow mb-2 notranslate" translate="no">{{ r.value }}</span>
          <span class="block text-on-primary font-bold text-body-md mb-1">{{ r.metric }}</span>
          <span class="block text-on-primary/60 text-label-md uppercase tracking-wider">{{ r.context }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ── Challenge / Approach / Outcome ── -->
<section class="py-16 md:py-24 bg-surface-off-white">
  <div class="section-container">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <div class="card p-8">
        <div class="w-12 h-12 rounded-xl bg-error/10 flex items-center justify-center mb-5">
          <span class="material-symbols-outlined text-error text-xl">crisis_alert</span>
        </div>
        <h2 class="text-headline-sm font-display text-on-surface mb-4">The Challenge</h2>
        <p class="text-body-md text-on-surface-variant leading-relaxed">{{ study.challenge }}</p>
      </div>

      <div class="card p-8 border-primary/30 bg-primary/5">
        <div class="w-12 h-12 rounded-xl bg-primary/15 flex items-center justify-center mb-5">
          <span class="material-symbols-outlined text-primary text-xl">build</span>
        </div>
        <h2 class="text-headline-sm font-display text-on-surface mb-4">Our Approach</h2>
        <p class="text-body-md text-on-surface-variant leading-relaxed">{{ study.approach }}</p>
      </div>

      <div class="card p-8">
        <div class="w-12 h-12 rounded-xl bg-action-yellow/20 flex items-center justify-center mb-5">
          <span class="material-symbols-outlined text-xl" style="color:#8B7200">trending_up</span>
        </div>
        <h2 class="text-headline-sm font-display text-on-surface mb-4">The Outcome</h2>
        <p class="text-body-md text-on-surface-variant leading-relaxed">{{ study.outcome }}</p>
      </div>

    </div>
  </div>
</section>

<!-- ── Testimonial ── -->
{% if study.testimonial %}
<section class="py-16">
  <div class="section-container">
    <blockquote class="max-w-3xl mx-auto text-center">
      <span class="material-symbols-outlined text-5xl text-primary/20 mb-4 block" style="font-variation-settings:'FILL' 1">format_quote</span>
      <p class="text-headline-sm font-display text-on-surface leading-relaxed mb-6 italic">
        "{{ study.testimonial }}"
      </p>
    </blockquote>
  </div>
</section>
{% endif %}

<!-- ── Technologies ── -->
{% if study.partners_used and study.partners_used.length %}
<section class="py-12 border-t border-outline-variant/10">
  <div class="section-container">
    <p class="eyebrow mb-8 text-center">Technologies Used</p>
    <div class="flex flex-wrap gap-4 justify-center">
      {% for pname in study.partners_used %}
        {% for p in partners %}
          {% if p.name == pname %}
            <a href="{{ p.href }}" target="_blank" rel="noopener noreferrer"
               class="card inline-flex items-center gap-3 px-6 py-4 w-auto">
              <img src="{{ p.logo }}" alt="{{ p.name }}" class="h-7 object-contain"
                   onerror="this.style.display='none';this.nextElementSibling.classList.remove('hidden')" />
              <span class="hidden font-bold text-primary">{{ p.name }}</span>
              <div>
                <p class="text-body-md font-bold text-on-surface">{{ p.name }}</p>
                <p class="text-label-md text-on-surface-variant">{{ p.category }}</p>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ── Solutions linked ── -->
{% if study.solutions_used and study.solutions_used.length %}
<section class="py-12 bg-surface-off-white">
  <div class="section-container">
    <p class="eyebrow mb-6">AKA Digital Solutions Deployed</p>
    <div class="flex flex-wrap gap-4">
      {% for slug in study.solutions_used %}
        {% set sol = solutions | findBySlug(slug) %}
        {% if sol %}
          <a href="{{ sol.href }}" class="card flex items-center gap-3 w-auto px-6 py-4">
            <span class="material-symbols-outlined text-primary text-xl">{{ sol.icon }}</span>
            <span class="text-body-md font-bold text-on-surface">{{ sol.short_title }}</span>
            <span class="material-symbols-outlined text-outline-variant text-base">arrow_forward</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ── Tags ── -->
{% if study.tags and study.tags.length %}
<section class="py-6 border-t border-outline-variant/10">
  <div class="section-container flex flex-wrap gap-2 items-center">
    <span class="text-label-md text-on-surface-variant mr-2 uppercase tracking-wider">Tags:</span>
    {% for tag in study.tags %}
      <span class="bg-surface-container rounded-full px-3 py-1 text-label-md text-on-surface-variant">{{ tag }}</span>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- ── CTA ── -->
<section class="py-20 bg-action-yellow">
  <div class="section-container text-center">
    <h2 class="text-headline-md font-display text-on-secondary-fixed mb-4 text-balance">
      Ready to achieve results like these?
    </h2>
    <p class="text-body-lg text-on-secondary-fixed/70 mb-8 max-w-md mx-auto">
      Talk to our team about your digital transformation goals across Southeast Asia.
    </p>
    <a href="/contact" class="btn-secondary border-on-secondary-fixed text-on-secondary-fixed hover:bg-on-secondary-fixed hover:text-action-yellow">
      Get a Free Consultation
    </a>
  </div>
</section>

{% endif %}
