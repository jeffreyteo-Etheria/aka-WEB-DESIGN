---
layout: layouts/base.njk
---
{# Individual blog post layout. Pages set: postSlug #}
{% set post = blogs | findBySlug(postSlug) %}

<!-- Blog Post Schema.org -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ post.title }}",
  "description": "{{ post.excerpt }}",
  "image": "{{ post.cover_image }}",
  "datePublished": "{{ post.date }}",
  "author": {
    "@type": "Person",
    "name": "{{ post.author }}"
  },
  "publisher": {
    "@id": "{{ settings.siteUrl }}/#organization"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ settings.siteUrl }}/blog/{{ post.slug }}"
  }
}
</script>

<!-- Breadcrumb -->
<nav class="pt-20 pb-4 bg-surface-off-white" aria-label="Breadcrumb">
  <div class="section-container">
    <ol class="flex items-center gap-2 text-label-md text-on-surface-variant" itemscope itemtype="https://schema.org/BreadcrumbList">
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a href="/" itemprop="item" class="hover:text-primary transition-colors"><span itemprop="name">Home</span></a>
        <meta itemprop="position" content="1" />
      </li>
      <span class="material-symbols-outlined text-base opacity-40">chevron_right</span>
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a href="/blog" itemprop="item" class="hover:text-primary transition-colors"><span itemprop="name">Blog</span></a>
        <meta itemprop="position" content="2" />
      </li>
      <span class="material-symbols-outlined text-base opacity-40">chevron_right</span>
      <li class="text-on-surface font-medium truncate max-w-xs" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span itemprop="name">{{ post.title | truncate(50) }}</span>
        <meta itemprop="position" content="3" />
      </li>
    </ol>
  </div>
</nav>

<!-- Hero -->
<section class="bg-surface-off-white pb-16">
  <div class="section-container max-w-4xl">
    <div class="flex items-center gap-3 mb-4">
      <span class="bg-primary/10 text-primary text-label-md font-bold px-3 py-1 rounded-full">{{ post.category }}</span>
      <span class="text-on-surface-variant text-label-md">{{ post.read_time }} min read</span>
      <span class="text-on-surface-variant text-label-md">·</span>
      <span class="text-on-surface-variant text-label-md">{{ post.date | dateFormat }}</span>
    </div>
    <h1 class="text-headline-lg md:text-headline-xl font-display text-on-surface mb-6 text-balance leading-tight">{{ post.title }}</h1>
    <p class="text-body-lg text-on-surface-variant mb-8 max-w-2xl leading-relaxed">{{ post.excerpt }}</p>
    <div class="flex items-center gap-4 pb-8 border-b border-outline-variant/20">
      <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center font-display font-bold text-primary text-body-lg shrink-0">
        {{ post.author | truncate(1, true, '') }}
      </div>
      <div>
        <span class="font-bold text-on-surface">{{ post.author }}</span>
        <span class="text-on-surface-variant text-label-md block">{{ post.author_title }}</span>
      </div>
      <!-- Tags -->
      <div class="ml-auto flex flex-wrap gap-2 justify-end">
        {% for tag in post.tags | first(3) %}
          <span class="bg-surface-container text-on-surface-variant text-label-md px-2.5 py-1 rounded-full text-xs">{{ tag }}</span>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- Cover image -->
<div class="relative w-full aspect-[21/9] max-h-[500px] overflow-hidden bg-surface-container">
  <img src="{{ post.cover_image }}" alt="{{ post.title }}"
    class="w-full h-full object-cover" loading="eager" />
  <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
</div>

<!-- Article body -->
<article class="py-16 md:py-20">
  <div class="section-container">
    <div class="grid md:grid-cols-12 gap-12">

      <!-- Main content -->
      <div class="md:col-span-8">
        <div class="prose prose-lg max-w-none
          prose-headings:font-display prose-headings:text-on-surface prose-headings:font-bold
          prose-p:text-on-surface-variant prose-p:leading-relaxed
          prose-a:text-primary prose-a:no-underline hover:prose-a:underline
          prose-strong:text-on-surface prose-strong:font-bold
          prose-li:text-on-surface-variant
          prose-table:w-full prose-th:text-left prose-th:p-3 prose-th:bg-surface-off-white prose-th:font-bold prose-td:p-3 prose-td:border-b prose-td:border-outline-variant/20
          ">
          {{ post.body_html | safe }}
        </div>

        <!-- Tags -->
        <div class="mt-12 pt-8 border-t border-outline-variant/20">
          <p class="text-label-md text-on-surface-variant uppercase tracking-wider mb-3">Tags</p>
          <div class="flex flex-wrap gap-2">
            {% for tag in post.tags %}
              <span class="bg-surface-container text-on-surface-variant border border-outline-variant/20 text-label-md px-3 py-1.5 rounded-full text-sm">{{ tag }}</span>
            {% endfor %}
          </div>
        </div>

        <!-- Author bio -->
        <div class="mt-10 p-6 bg-surface-off-white border border-outline-variant/20 rounded-2xl flex items-start gap-5">
          <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center font-display font-bold text-primary text-headline-sm shrink-0">
            {{ post.author | truncate(1, true, '') }}
          </div>
          <div>
            <span class="font-display font-bold text-on-surface text-body-lg">{{ post.author }}</span>
            <span class="text-on-surface-variant text-label-md block mb-2">{{ post.author_title }}</span>
            <p class="text-body-md text-on-surface-variant leading-relaxed text-sm">AKA Digital is Southeast Asia's leading B2B MarTech agency — Vietnam's exclusive representative for world-class marketing technology platforms, licensed to operate across the region.</p>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="md:col-span-4">
        <!-- CTA card -->
        <div class="bg-primary text-on-primary rounded-2xl p-6 mb-8 sticky top-24">
          <h3 class="font-display font-bold text-on-primary text-headline-sm mb-3">Talk to a MarTech Expert</h3>
          <p class="text-on-primary/70 text-body-md mb-5 leading-relaxed">Get a free consultation and custom roadmap for your business from our SEA team.</p>
          <a href="/contact" class="block w-full text-center bg-action-yellow text-on-secondary-fixed font-extrabold py-3 rounded-xl text-label-md uppercase tracking-wider hover:shadow-lg transition-all">
            Book Free Session
          </a>
          <div class="mt-4 pt-4 border-t border-white/10 text-center">
            <span class="text-on-primary/40 text-label-md">150+ enterprise brands served</span>
          </div>
        </div>

        <!-- Related posts -->
        <div>
          <p class="eyebrow mb-4">Related Articles</p>
          <div class="space-y-4">
            {% for related in blogs %}
              {% if related.slug != post.slug %}
                <a href="/blog/{{ related.slug }}" class="group flex gap-3 card p-3 hover:border-primary/40 transition-all">
                  <img src="{{ related.cover_image }}" alt="{{ related.title }}" class="w-16 h-12 object-cover rounded-lg shrink-0" loading="lazy" />
                  <div class="min-w-0">
                    <span class="text-label-md text-primary font-bold text-xs uppercase">{{ related.category }}</span>
                    <p class="text-body-md text-on-surface font-medium text-sm leading-snug group-hover:text-primary transition-colors line-clamp-2">{{ related.title }}</p>
                  </div>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </aside>

    </div>
  </div>
</article>

<!-- Back to blog -->
<div class="py-12 bg-surface-off-white text-center">
  <a href="/blog" class="inline-flex items-center gap-2 text-primary font-bold text-label-md hover:gap-3 transition-all">
    <span class="material-symbols-outlined text-base">arrow_back</span> Back to all articles
  </a>
</div>
