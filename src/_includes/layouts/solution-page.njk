---
layout: layouts/base.njk
---
{# Shared layout for all four solution pages.
   Pages supply: solutionSlug (string matching slug in solutions.json) #}
{% set sol = solutions | findBySlug(solutionSlug) %}

<!-- Hero -->
<section class="relative py-28 bg-white overflow-hidden">
  <!-- Faint background images -->
  <div class="absolute inset-0 z-0">
    {% if sol.hero_image_2 %}
      <div class="w-full h-full grid grid-cols-2">
        <div class="relative overflow-hidden">
          <img src="{{ sol.hero_image }}" alt="" role="presentation"
               class="w-full h-full object-cover opacity-[0.07]" loading="eager" />
        </div>
        <div class="relative overflow-hidden">
          <img src="{{ sol.hero_image_2 }}" alt="" role="presentation"
               class="w-full h-full object-cover opacity-[0.07]" loading="eager" />
        </div>
      </div>
    {% else %}
      <img src="{{ sol.hero_image }}" alt="" role="presentation"
           class="w-full h-full object-cover opacity-[0.06]" loading="eager" />
    {% endif %}
  </div>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-primary/5 blur-[120px] pointer-events-none -translate-y-1/3 translate-x-1/4 z-0"></div>
  <div class="relative z-10 section-container">
    <a href="/solutions" class="inline-flex items-center gap-1 text-label-md text-on-surface-variant hover:text-primary transition-colors mb-6">
      <span class="material-symbols-outlined text-base">arrow_back</span> All Solutions
    </a>
    <div class="max-w-2xl">
      <div class="w-14 h-14 rounded-xl bg-primary flex items-center justify-center text-on-primary mb-6">
        <span class="material-symbols-outlined text-3xl">{{ sol.icon }}</span>
      </div>
      <p class="eyebrow text-primary mb-3">Solution</p>
      <h1 class="text-headline-lg-mobile md:text-headline-lg font-display font-bold text-on-surface mb-4 text-balance">
        {{ sol.title }}
      </h1>
      <p class="text-headline-sm font-display text-action-yellow mb-6">{{ sol.tagline }}</p>
      <p class="text-body-lg text-on-surface-variant max-w-xl leading-relaxed">{{ sol.description }}</p>
      {% if sol.industries %}
      <div class="mt-6">
        <p class="text-label-md text-on-surface-variant/60 uppercase tracking-widest mb-2">Industry Sectors</p>
        <div class="flex flex-wrap gap-2">
          {% for ind in sol.industries %}
            <span class="bg-on-surface/8 border border-on-surface/15 text-on-surface rounded-full px-3 py-1 text-label-md font-medium">{{ ind }}</span>
          {% endfor %}
        </div>
      </div>
      {% endif %}
      {% if sol.channels %}
      <div class="mt-4">
        <p class="text-label-md text-on-surface-variant/60 uppercase tracking-widest mb-2">Programmatic Channels</p>
        <div class="flex flex-wrap gap-2">
          {% for ch in sol.channels %}
            <span class="bg-primary/10 border border-primary/20 text-primary rounded-full px-3 py-1 text-label-md font-medium">{{ ch }}</span>
          {% endfor %}
        </div>
      </div>
      {% endif %}
      <div class="mt-8">
        <a href="/contact" class="btn-primary">Get a Free Consultation</a>
      </div>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="py-16 bg-surface-off-white">
  <div class="section-container">
    <div class="text-center mb-10">
      <p class="eyebrow mb-3">Our Process</p>
      <h2 class="text-headline-md font-display text-on-surface">How We Deliver Results</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-0">

      <!-- Step 1 -->
      <div class="relative flex md:flex-col gap-4 md:gap-0 items-start md:items-center card md:rounded-r-none md:border-r-0 p-6 md:p-8 md:text-center">
        <div class="w-12 h-12 rounded-full bg-primary text-on-primary flex items-center justify-center font-display font-extrabold text-headline-sm shrink-0">1</div>
        <div class="md:mt-4">
          <h3 class="font-display font-bold text-body-md text-on-surface mb-1 md:mb-2">Discovery & Strategy</h3>
          <p class="text-body-md text-on-surface-variant leading-relaxed">We audit your current stack, define objectives, and build a tailored MarTech roadmap aligned with your business goals and budget.</p>
        </div>
        <!-- Desktop connector -->
        <div class="hidden md:flex absolute top-10 -right-5 z-10 w-10 items-center justify-center">
          <span class="material-symbols-outlined text-2xl text-outline-variant">chevron_right</span>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative flex md:flex-col gap-4 md:gap-0 items-start md:items-center card md:rounded-none md:border-x-0 p-6 md:p-8 md:text-center">
        <div class="w-12 h-12 rounded-full bg-primary text-on-primary flex items-center justify-center font-display font-extrabold text-headline-sm shrink-0">2</div>
        <div class="md:mt-4">
          <h3 class="font-display font-bold text-body-md text-on-surface mb-1 md:mb-2">Implementation & Integration</h3>
          <p class="text-body-md text-on-surface-variant leading-relaxed">Our certified team handles full platform setup, data integration, and team training — fast, structured, and without disrupting operations.</p>
        </div>
        <div class="hidden md:flex absolute top-10 -right-5 z-10 w-10 items-center justify-center">
          <span class="material-symbols-outlined text-2xl text-outline-variant">chevron_right</span>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex md:flex-col gap-4 md:gap-0 items-start md:items-center card md:rounded-l-none md:border-l-0 p-6 md:p-8 md:text-center">
        <div class="w-12 h-12 rounded-full bg-action-yellow text-on-secondary-fixed flex items-center justify-center font-display font-extrabold text-headline-sm shrink-0">3</div>
        <div class="md:mt-4">
          <h3 class="font-display font-bold text-body-md text-on-surface mb-1 md:mb-2">Optimise & Scale</h3>
          <p class="text-body-md text-on-surface-variant leading-relaxed">We monitor, test, and continuously improve performance — reporting clearly on what's working and scaling what drives results.</p>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- Benefits -->
<section class="py-16 md:py-24">
  <div class="section-container">
    <div class="md:grid md:grid-cols-2 md:gap-16">
      <div>
        <p class="eyebrow mb-4">Key Benefits</p>
        <h2 class="text-headline-md font-display text-on-surface mb-8 text-balance">
          What you get with AKA Digital
        </h2>
        <ul class="space-y-4">
          {% for benefit in sol.benefits %}
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary shrink-0 mt-0.5">
                <span class="material-symbols-outlined text-sm">check</span>
              </div>
              <span class="text-body-lg text-on-surface-variant">{{ benefit }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>
      <div class="mt-10 md:mt-0">
        <p class="eyebrow mb-4">Use Cases</p>
        <h2 class="text-headline-md font-display text-on-surface mb-8 text-balance">
          Who we help
        </h2>
        <ul class="space-y-4">
          {% for uc in sol.use_cases %}
            <li class="flex items-start gap-3 pb-4 border-b border-outline-variant/20 last:border-0">
              <span class="material-symbols-outlined text-primary shrink-0 mt-0.5">bolt</span>
              <span class="text-body-lg text-on-surface-variant">{{ uc }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Inject page content (related case studies etc.) -->
{{ content | safe }}

<!-- CTA band -->
<section class="py-20 bg-action-yellow">
  <div class="section-container text-center">
    <h2 class="text-headline-md font-display text-on-secondary-fixed mb-4">Ready to get started?</h2>
    <p class="text-body-lg text-on-secondary-fixed/70 mb-8 max-w-md mx-auto">
      Talk to our team about implementing {{ sol.short_title }} for your business.
    </p>
    <a href="/contact" class="btn-secondary border-on-secondary-fixed text-on-secondary-fixed hover:bg-on-secondary-fixed hover:text-action-yellow">
      Book a Consultation
    </a>
  </div>
</section>
