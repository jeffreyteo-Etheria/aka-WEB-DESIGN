<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description if description else settings.description }}" />
  <link rel="canonical" href="{{ settings.siteUrl }}{{ page.url }}" />

  <!-- Open Graph -->
  <meta property="og:title"        content="{{ title if title else settings.name }}" />
  <meta property="og:description"  content="{{ description if description else settings.description }}" />
  <meta property="og:image"        content="{{ settings.siteUrl }}/images/logos/aka-digital-og.jpg" />
  <meta property="og:url"          content="{{ settings.siteUrl }}{{ page.url }}" />
  <meta property="og:type"         content="website" />
  <meta property="og:site_name"    content="AKA Digital" />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="{{ title if title else settings.name }}" />
  <meta name="twitter:description" content="{{ description if description else settings.description }}" />
  <meta name="twitter:image"       content="{{ settings.siteUrl }}/images/logos/aka-digital-og.jpg" />

  <title>{{ title if title else settings.name }}</title>

  <!-- Compiled Tailwind CSS (generated by: npm run css:build) -->
  <link rel="stylesheet" href="/css/main.css" />

  <!-- Brand fonts: Playfair Display (display/headings) + JetBrains Mono (labels/data) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700&family=JetBrains+Mono:wght@400;600&display=swap" />

  <!-- Material Symbols icons — only CDN dependency; see EXPORT_GUIDE.md §4 for offline option -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/logos/favicon.png" />
  <link rel="apple-touch-icon"       href="/images/logos/apple-touch-icon.png" />

  <!-- Organisation + WebSite schema (sitewide) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ settings.siteUrl }}/#organization",
        "name": "AKA Digital",
        "url": "{{ settings.siteUrl }}",
        "logo": "{{ settings.siteUrl }}/images/logos/AKA%20Logo%20-%20New%20-%202025.10.png",
        "description": "Award-winning B2B marketing technology agency and Vietnam's exclusive representative for leading global MarTech platforms — licensed to operate across Southeast Asia.",
        "foundingDate": "2014",
        "areaServed": ["VN","SG","ID","KR","TH","MY","PH"],
        "contactPoint": [
          {
            "@type": "ContactPoint",
            "telephone": "+65-8699-9719",
            "contactType": "sales",
            "areaServed": "SG",
            "availableLanguage": ["English"]
          },
          {
            "@type": "ContactPoint",
            "telephone": "+84-90-3045-373",
            "contactType": "sales",
            "areaServed": "VN",
            "availableLanguage": ["Vietnamese","English"]
          }
        ],
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "1 Paya Lebar Link, #04-01, Paya Lebar Quarter",
          "addressLocality": "Singapore",
          "postalCode": "408533",
          "addressCountry": "SG"
        },
        "sameAs": [
          "{{ settings.social.linkedin }}",
          "{{ settings.social.youtube }}"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "{{ settings.siteUrl }}/#website",
        "url": "{{ settings.siteUrl }}",
        "name": "AKA Digital",
        "publisher": { "@id": "{{ settings.siteUrl }}/#organization" }
      }
    ]
  }
  </script>

  <!-- Page-specific head injection -->
  {{ head | safe if head }}
</head>
<body class="bg-background text-on-surface font-body overflow-x-hidden" id="top">

  {% include "components/nav.njk" %}

  <!-- Language translation notice (shown when non-English is active) -->
  <div id="lang-notice" class="hidden bg-primary/10 border-b border-primary/20 px-4 py-2 text-center">
    <p class="text-label-md text-primary">
      <span class="material-symbols-outlined text-sm align-middle mr-1">translate</span>
      <span data-lang-notice-text>Content translated via machine translation.</span>
      <button onclick="document.querySelectorAll('.lang-btn[data-lang=en]').forEach(function(b){b.click()})" class="ml-2 underline font-bold hover:text-primary/80">Switch to English</button>
    </p>
  </div>

  <main class="pt-16">
    {{ content | safe }}
  </main>

  {% include "components/footer.njk" %}

  <!-- ── Reading progress bar (shows on article/solution pages) ── -->
  {% if ("/blog/" in page.url) or ("/solutions/" in page.url) or ("/case-studies/" in page.url) or ("/insights/" in page.url) %}
  <div class="fixed top-16 left-0 w-full h-0.5 bg-outline-variant/20 z-40 pointer-events-none">
    <div id="reading-progress" class="h-full bg-primary transition-all duration-100" style="width:0%"></div>
  </div>
  {% endif %}

  <!-- ── Sticky CTA bar (slides up after scroll) ── -->
  <div id="sticky-cta-bar"
       class="fixed bottom-0 left-0 right-0 z-50 translate-y-full opacity-0 transition-all duration-300 ease-out
              bg-[#060F24] border-t border-white/10 shadow-[0_-4px_32px_rgba(0,0,0,0.4)]"
       aria-hidden="true">
    <div class="section-container py-3 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <span class="material-symbols-outlined text-action-yellow shrink-0" style="font-variation-settings:'FILL' 1">bolt</span>
        <p class="text-white text-label-md font-medium truncate hidden sm:block">Ready to transform your MarTech stack? Get a free strategy consultation.</p>
        <p class="text-white text-label-md font-medium truncate sm:hidden">Free MarTech consultation</p>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <a href="{{ settings.cta.get_started_url }}" class="btn-primary text-xs py-2.5 px-5 whitespace-nowrap">{{ settings.cta.get_started_text }}</a>
        <button id="sticky-cta-close" class="text-white/50 hover:text-white transition-colors"
                onclick="document.getElementById('sticky-cta-bar').classList.add('hidden')"
                aria-label="Close">
          <span class="material-symbols-outlined text-base">close</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Exit-intent Lead Capture Popup ── -->
  <div id="exit-intent-popup"
       class="hidden fixed inset-0 z-[100] bg-black/60 backdrop-blur-sm flex items-center justify-center p-4"
       role="dialog" aria-modal="true" aria-label="Free consultation offer">
    <div class="exit-popup-inner relative scale-95 opacity-0 transition-all duration-300
                bg-white rounded-2xl max-w-lg w-full shadow-2xl overflow-hidden">
      <!-- Top accent bar -->
      <div class="h-1.5 bg-gradient-to-r from-primary to-action-yellow"></div>
      <div class="p-8">
        <button data-close-exit
                class="absolute top-4 right-4 text-on-surface-variant hover:text-on-surface transition-colors"
                aria-label="Close">
          <span class="material-symbols-outlined">close</span>
        </button>
        <div class="mb-6">
          <div class="inline-flex items-center gap-2 bg-action-yellow/20 text-on-surface px-3 py-1 rounded-full text-label-md font-bold mb-4">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1">auto_awesome</span>
            Before you go
          </div>
          <h2 class="font-display font-extrabold text-on-surface text-2xl leading-tight mb-2">
            {{ settings.popup.title }}
          </h2>
          <p class="text-on-surface-variant text-body-md">{{ settings.popup.subtitle }}</p>
        </div>
        <div class="space-y-4 mb-6">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-base mt-0.5 shrink-0" style="font-variation-settings:'FILL' 1">check_circle</span>
            <div>
              <span class="text-label-md font-bold text-on-surface">{{ settings.popup.bullet_1_title }}</span>
              <p class="text-label-sm text-on-surface-variant mt-0.5">{{ settings.popup.bullet_1_sub }}</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-base mt-0.5 shrink-0" style="font-variation-settings:'FILL' 1">check_circle</span>
            <div>
              <span class="text-label-md font-bold text-on-surface">{{ settings.popup.bullet_2_title }}</span>
              <p class="text-label-sm text-on-surface-variant mt-0.5">{{ settings.popup.bullet_2_sub }}</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-base mt-0.5 shrink-0" style="font-variation-settings:'FILL' 1">check_circle</span>
            <div>
              <span class="text-label-md font-bold text-on-surface">{{ settings.popup.bullet_3_title }}</span>
              <p class="text-label-sm text-on-surface-variant mt-0.5">{{ settings.popup.bullet_3_sub }}</p>
            </div>
          </div>
        </div>
        <a href="{{ settings.popup.button_url }}" data-close-exit onclick="document.getElementById('exit-intent-popup').classList.add('hidden'); document.body.style.overflow=''"
           class="btn-primary w-full justify-center mb-3">
          {{ settings.popup.button_text }}
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
        <button data-close-exit class="w-full text-on-surface-variant text-label-md hover:text-on-surface transition-colors py-2">
          No thanks, I'll continue browsing
        </button>
      </div>
    </div>
  </div>

  <!-- Core scripts (defer = non-blocking) -->
  <script src="/js/i18n.js"        defer></script>
  <script src="/js/nav.js"         defer></script>
  <script src="/js/carousel.js"    defer></script>
  <script src="/js/form.js"        defer></script>
  <script src="/js/main.js"        defer></script>
  <script src="/js/animations.js"  defer></script>
  <script src="/js/lead-gen.js"    defer></script>

  <!-- Page-specific script injection -->
  {{ scripts | safe if scripts }}
</body>
</html>
