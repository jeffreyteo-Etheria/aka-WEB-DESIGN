<!-- ============================================================
     CASE STUDY VIDEO SPOTLIGHT — grouped by category, 4 columns
     ============================================================ -->
<section class="py-20 md:py-32 bg-background">
  <div class="section-container">
    <div class="text-center mb-16 reveal-up">
      <p class="eyebrow mb-3">Proven Results</p>
      <h2 class="text-headline-md md:text-headline-lg font-display text-on-surface">Award-winning Campaigns</h2>
      <p class="text-body-lg text-on-surface-variant mt-4 max-w-xl mx-auto">Real campaigns, real brands, real Southeast Asia results.</p>
    </div>

    {% set categories = [
      { slug: "crm-automation",   label: "CRM & Automation",          icon: "hub" },
      { slug: "programmatic-audio", label: "Programmatic & Audio",    icon: "campaign" },
      { slug: "social-influencer",  label: "Social Media & Influencer", icon: "groups" }
    ] %}

    {% for cat in categories %}
      <div class="mb-14 reveal-up">
        <div class="flex items-center gap-3 mb-6">
          <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings:'FILL' 1">{{ cat.icon }}</span>
          <span class="text-label-md font-bold text-on-surface-variant uppercase tracking-widest">{{ cat.label }}</span>
          <div class="flex-1 h-px bg-outline-variant/20 ml-1"></div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
          {% for cs in case_studies | publishedOnly %}
            {% if cs.category == cat.slug and cs.featured_home %}
              <a href="/case-studies/{{ cs.slug }}" class="group card overflow-hidden hover:shadow-[0_20px_60px_rgba(37,59,194,0.12)] hover:-translate-y-1 transition-all duration-300">
                <div class="relative aspect-video overflow-hidden bg-on-surface">
                  {% if cs.video_cover %}
                    <video
                      src="{{ cs.video_cover }}"
                      poster="{{ cs.video_thumbnail }}"
                      autoplay muted loop playsinline
                      class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
                    ></video>
                  {% else %}
                    <img src="{{ cs.video_thumbnail }}"
                      alt="{{ cs.client }} case study"
                      class="w-full h-full object-cover opacity-70 group-hover:opacity-85 group-hover:scale-105 transition-all duration-500"
                      loading="lazy"
                      onerror="this.src='{{ cs.cover_image }}'"
                    />
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="w-10 h-10 bg-action-yellow rounded-full flex items-center justify-center shadow-[0_8px_24px_rgba(245,209,0,0.4)] group-hover:scale-110 transition-transform duration-300">
                        <span class="material-symbols-outlined text-on-secondary-fixed text-lg" style="font-variation-settings:'FILL' 1">play_arrow</span>
                      </div>
                    </div>
                  {% endif %}
                  {% if cs.award %}
                    <div class="absolute top-2 left-2">
                      <span class="bg-action-yellow text-on-secondary-fixed font-bold px-2 py-0.5 rounded-full text-[10px]">{{ cs.award }}</span>
                    </div>
                  {% endif %}
                  <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/80 to-transparent">
                    <p class="text-white font-bold text-xs">{{ cs.client }}</p>
                    <p class="text-white/60 text-[10px]">{{ cs.industry }} · {{ cs.country }}</p>
                  </div>
                </div>
                <div class="p-4">
                  <h3 class="text-body-md font-display font-bold text-on-surface mb-3 leading-snug group-hover:text-primary transition-colors line-clamp-2">{{ cs.title }}</h3>
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {% for r in cs.results %}
                      {% if loop.index <= 2 %}
                        <div class="bg-primary/8 rounded-lg px-2 py-1 text-center">
                          <span class="block text-primary font-display font-extrabold text-sm leading-none">{{ r.value }}</span>
                          <span class="text-[9px] text-on-surface-variant uppercase tracking-wider">{{ r.metric }}</span>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                  <div class="flex items-center gap-1 text-primary font-bold text-xs group-hover:gap-2 transition-all">
                    Read case study <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </div>
                </div>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}

    <div class="text-center mt-6">
      <a href="/case-studies" class="btn-secondary">View all case studies</a>
    </div>
  </div>
</section>


