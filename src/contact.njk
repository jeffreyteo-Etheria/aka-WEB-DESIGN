    <div class="p-8">
      <button onclick="closeContactThankYou()"
              class="absolute top-4 right-4 text-on-surface-variant hover:text-on-surface transition-colors" aria-label="Close">
        <span class="material-symbols-outlined">close</span>
      </button>
      <span class="material-symbols-outlined text-primary text-5xl block mb-4" style="font-variation-settings:'FILL' 1">check_circle</span>
      <h2 class="font-display font-extrabold text-on-surface text-2xl mb-2">Thank you!</h2>
      <p class="text-on-surface-variant text-body-md mb-6">Your enquiry has been sent. Your assigned contact will respond within 1 business day.</p>
      <button onclick="closeContactThankYou()" class="btn-primary w-full justify-center">Got it</button>
    </div>
  </div>
</div>
<script>
function closeContactThankYou() {
  var modal = document.getElementById('contact-thankyou-modal');
  var inner = document.getElementById('contact-thankyou-inner');
  inner.classList.remove('scale-100', 'opacity-100');
  inner.classList.add('scale-95', 'opacity-0');
  document.body.style.overflow = '';
  setTimeout(function () { modal.classList.add('hidden'); }, 200);
}
function openContactThankYou() {
  var modal = document.getElementById('contact-thankyou-modal');
  var inner = document.getElementById('contact-thankyou-inner');
  modal.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  requestAnimationFrame(function () {
    inner.classList.remove('scale-95', 'opacity-0');
    inner.classList.add('scale-100', 'opacity-100');
  });
}
</script>


<script>
/* ============================================================
   Smart Contact Routing Logic
   ============================================================ */
(function () {
  var CONTACTS = {
    vn: {
      name: "Ms. Phuong Pham (Maisie)",
      title: "Country Director, Vietnam",
      email: "phuong.pham@akadigital.net",
      phone: "+84903045373",
      photo: "/images/team/phuong-pham.jpg",
      channel: "WhatsApp / Zalo",
      waHref: "https://wa.me/84903045373",
      marketLabel: "🇻🇳 Vietnam Contact"
    },
    sg: {
      name: "Jeffrey Teo",
      title: "Country Director, Regional Markets (SG · MY · ID)",
      email: "jeffrey.teo@akadigital.net",
      phone: "+6586999719",
      photo: "/images/team/jeffrey-teo.jpg",
      channel: "WhatsApp",
      waHref: "https://wa.me/6586999719",
      marketLabel: "🇸🇬 Singapore & SEA Contact"
    },
    sea: {
      name: "Jeffrey Teo",
      title: "Country Director, Regional Markets (SG · MY · ID)",
      email: "jeffrey.teo@akadigital.net",
      phone: "+6586999719",
      photo: "/images/team/jeffrey-teo.jpg",
      channel: "WhatsApp",
      waHref: "https://wa.me/6586999719",
      marketLabel: "🌏 Southeast Asia Contact"
    },
    kr: {
      name: "KS Hwang",
      title: "Country Director, South Korea",
      email: "kw.hwang@akadigital.net",
      phone: "+821023353076",
      photo: "/images/team/ks-hwang.jpg",
      channel: "LINE / Phone / WhatsApp",
      waHref: "https://wa.me/821023353076",
      marketLabel: "🇰🇷 Korea Contact"
    }
  };

  var selectedMarket = null;

  function selectMarket(market) {
    selectedMarket = market;
    var contact = CONTACTS[market];
    if (!contact) return;

    // Update button states
    document.querySelectorAll(".market-btn").forEach(function (btn) {
      var active = btn.dataset.market === market;
      btn.classList.toggle("border-primary", active);
      btn.classList.toggle("bg-primary/5", active);
      btn.classList.toggle("border-outline-variant/30", !active);
    });

    // Populate contact card
    document.getElementById("contact-photo").src = contact.photo;
    document.getElementById("contact-photo").alt = contact.name;
    document.getElementById("contact-market-label").textContent = contact.marketLabel;
    document.getElementById("contact-name").textContent = contact.name;
    document.getElementById("contact-title").textContent = contact.title;
    document.getElementById("contact-email-text").textContent = contact.email;
    document.getElementById("contact-email-link").href = "mailto:" + contact.email;
    document.getElementById("contact-channel-text").textContent = contact.channel;
    document.getElementById("contact-wa-link").href = contact.waHref;

    // Set hidden form fields
    document.getElementById("form-market").value = market;
    document.getElementById("form-assigned-to").value = contact.email;

    // Show sections
    document.getElementById("contact-assignment").classList.remove("hidden");
    document.getElementById("contact-form-section").classList.remove("hidden");

    // Smooth scroll to form
    setTimeout(function () {
      document.getElementById("contact-assignment").scrollIntoView({ behavior: "smooth", block: "nearest" });
    }, 100);
  }

  // Wire market buttons
  document.querySelectorAll(".market-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      selectMarket(btn.dataset.market);
    });
  });

  // Form submission via Google Forms (no-cors)
  var form = document.getElementById("smart-contact-form");
  form.addEventListener("submit", function (e) {
    e.preventDefault();

    // Validate required fields
    var valid = true;
    ["fc-name", "fc-company", "fc-email", "fc-type"].forEach(function (id) {
      var el = document.getElementById(id);
      if (!el.value.trim()) {
        el.style.outline = "2px solid #ba1a1a";
        valid = false;
      } else {
        el.style.outline = "";
      }
    });
    if (!valid) return;

    var submitBtn = document.getElementById("smart-form-submit");
    var submitText = document.getElementById("smart-submit-text");
    var spinner = document.getElementById("smart-submit-spinner");
    submitBtn.disabled = true;
    submitText.classList.add("hidden");
    spinner.classList.remove("hidden");

    var contact = CONTACTS[selectedMarket || "sg"];
    var payload = {
      form_type:    'lead',
      source_page:  window.location.pathname,
      market:       selectedMarket || 'sg',
      assigned_to:  contact.email,
      name:         document.getElementById("fc-name").value,
      company:      document.getElementById("fc-company").value,
      email:        document.getElementById("fc-email").value,
      phone:        document.getElementById("fc-phone").value,
      inquiry_type: document.getElementById("fc-type").value,
      message:      document.getElementById("fc-message").value
    };

    var webhookUrl = "{{ cms_settings.webhook_url }}";
    if (webhookUrl && webhookUrl.indexOf('REPLACE') === -1) {
      fetch(webhookUrl, {
        method: "POST",
        mode:   "no-cors",
        headers: { "Content-Type": "application/json" },
        body:   JSON.stringify(payload)
      }).catch(function(){}).finally(function() { showSuccess(); });
    } else {
      // Fallback mailto if webhook not yet configured
      var mailBody = Object.entries(payload).map(function(p){return p[0]+': '+p[1];}).join('\n');
      window.location.href = "mailto:" + contact.email + "?cc=Hello@akadigital.net&subject=Website Enquiry — " + encodeURIComponent(payload.inquiry_type || "General") + "&body=" + encodeURIComponent(mailBody);
      showSuccess();
    }
  });

  function showSuccess() {
    document.getElementById("smart-form-submit").classList.add("hidden");
    document.getElementById("smart-form-success").classList.remove("hidden");
    document.getElementById("smart-contact-form").reset();
    openContactThankYou();
  }

  // Auto-select market from URL param ?market=vn
  var urlParams = new URLSearchParams(window.location.search);
  var mkt = urlParams.get("market");
  if (mkt && CONTACTS[mkt]) {
    selectMarket(mkt);
  }
})();
</script>
