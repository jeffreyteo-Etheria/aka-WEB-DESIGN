---
layout: layouts/base.njk
title: Tech Partners | AKA Digital
description: AKA Digital is a licensed integrator for world-class MarTech platforms across Vietnam and Southeast Asia. Explore our certified global partner ecosystem.
---

<!-- ============================================================
     HERO
     ============================================================ -->
<section class="relative py-24 bg-surface-off-white overflow-hidden">
  <!-- Subtle grid -->
  <div class="absolute inset-0 opacity-[0.03]"
       style="background-image: linear-gradient(var(--color-on-surface) 1px, transparent 1px), linear-gradient(90deg, var(--color-on-surface) 1px, transparent 1px); background-size: 60px 60px;">
  </div>
  <div class="relative section-container">
    <div class="md:grid md:grid-cols-2 md:gap-16 items-center">
      <div>
        <p class="eyebrow mb-4">Our Partner Ecosystem</p>
        <h1 class="text-headline-lg-mobile md:text-headline-lg font-display text-on-surface mb-6 text-balance">
          World-Class Platforms.<br/>Regional Expertise.
        </h1>
        <p class="text-body-lg text-on-surface-variant max-w-xl leading-relaxed">
          Global Tech Partnerships &amp; Licensed Tech Stack Integrator for Emerging Markets (Vietnam).
          Bringing world-class global technology to Vietnam through a fully certified, dedicated local engineering team.
        </p>
        <a href="/contact" class="btn-primary mt-8">
          Get access to these platforms
          <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>

      <!-- Partner logo pills -->
      <div class="hidden md:flex flex-wrap gap-3 justify-end">
        {% for partner in partners %}
          <div class="bg-white border border-outline-variant/20 rounded-2xl px-5 py-3 flex items-center gap-3 shadow-sm hover:shadow-md hover:border-primary/30 transition-all">
            <div class="w-10 h-10 rounded-lg bg-white border border-outline-variant/10 flex items-center justify-center p-1.5 shrink-0 overflow-hidden">
              <img
                src="{{ partner.logo }}"
                alt="{{ partner.name }}"
                class="max-h-full max-w-full object-contain"
                onerror="this.style.display='none'; this.parentElement.innerHTML='<span class=\'font-display font-extrabold text-label-md text-primary\'>{{ partner.name | truncate(2, true, "") }}</span>'"
                loading="lazy"
              />
            </div>
            <div>
              <p class="font-display font-bold text-body-md text-on-surface" translate="no">{{ partner.name }}</p>
              <p class="text-label-md text-primary font-semibold" translate="no">{{ partner.category }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>


<!-- ============================================================
     PARTNERS DETAIL GRID
     ============================================================ -->
<section class="py-16 md:py-24">
  <div class="section-container">
    <div class="text-center mb-4">
      <p class="eyebrow mb-3">The Platforms</p>
      <h2 class="text-headline-md font-display text-on-surface">Our MarTech Partner Ecosystem</h2>
    </div>
    <div class="text-center mb-12 max-w-2xl mx-auto">
      <p class="text-body-lg text-on-surface-variant leading-relaxed">
        Global Tech Partnerships &amp; Licensed Tech Stack Integrator for Emerging Markets (Vietnam).<br/>
        <span class="text-body-md text-on-surface-variant/80">Bringing world-class global technology to Vietnam through a fully certified, dedicated local engineering team.</span>
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {% for partner in partners %}
        <div class="card flex flex-col gap-5 p-8 hover:border-primary/30 hover:shadow-[0_8px_32px_rgba(37,59,194,0.08)] transition-all duration-300">

          <!-- Logo + name header -->
          <div class="flex items-center gap-4 pb-5 border-b border-outline-variant/20">
            <div class="w-20 h-20 rounded-2xl bg-white border border-outline-variant/15 flex items-center justify-center p-3 shrink-0 shadow-sm">
              <img
                src="{{ partner.logo }}"
                alt="{{ partner.name }}"
                class="max-h-full max-w-full object-contain"
                onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden')"
                loading="lazy"
              />
              <span class="hidden font-display font-extrabold text-headline-sm text-primary" translate="no">{{ partner.name | truncate(2, true, "") }}</span>
            </div>
            <div class="flex-1">
              <h2 class="text-headline-sm font-display text-on-surface" translate="no">{{ partner.name }}</h2>
              <span class="text-label-md font-bold text-primary uppercase tracking-wider" translate="no">{{ partner.category }}</span>
            </div>
            {% if partner.exclusive_note %}
            <span class="hidden md:block text-label-md text-on-surface-variant bg-surface-container-low rounded-full px-3 py-1 shrink-0 text-xs">
              {{ partner.exclusive_note }}
            </span>
            {% endif %}
          </div>

          <!-- Description / Key Solutions Benefits -->
          <p class="text-body-md text-on-surface-variant leading-relaxed flex-1">{{ partner.description }}</p>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-3 pt-2 border-t border-outline-variant/10">
            <a
              href="/contact?inquiry=partner-demo&amp;partner={{ partner.name | urlencode }}"
              class="btn-ghost"
            >
              Request Demo
              <span class="material-symbols-outlined text-base">arrow_forward</span>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>


<!-- ============================================================
     CTA BAND
     ============================================================ -->
<section class="py-20 bg-primary text-on-primary text-center">
  <div class="section-container">
    <p class="text-label-md font-bold text-on-primary/60 uppercase tracking-widest mb-3">Get Access</p>
    <h2 class="text-headline-md font-display text-on-primary mb-4">Start working with these platforms</h2>
    <p class="text-body-lg text-on-primary/80 mb-8 max-w-md mx-auto">
      As AKA Digital's certified regional integrator, we handle licensing, implementation, and ongoing support so you can focus on results.
    </p>
    <a href="/contact" class="btn-primary">Talk to Our Team</a>
  </div>
</section>
