<!-- Hero -->
<section class="py-24 bg-on-surface text-inverse-on-surface overflow-hidden relative">
  <div class="absolute inset-0 z-0">
    <img src="/images/hero/home-summit.jpeg" alt="" role="presentation"
         class="w-full h-full object-cover opacity-15" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-on-surface via-on-surface/85 to-on-surface/50"></div>
  </div>
  <div class="relative z-10 section-container">
    <p class="eyebrow text-primary-fixed mb-4">Knowledge Hub</p>
    <h1 class="text-headline-lg font-display text-inverse-on-surface mb-6 max-w-2xl text-balance">
      MarTech Insights for Southeast Asia
    </h1>
    <p class="text-body-lg text-inverse-on-surface/70 max-w-xl">
      Event recaps, media coverage, platform guides, and thought leadership from our team and partner ecosystem.
    </p>
    <div class="flex gap-4 mt-8">
      <a href="#activities" class="btn-primary">Activities &amp; Events</a>
      <a href="#media" class="btn-ghost border-white/30 text-white/80 hover:text-white hover:border-white/60">Media Coverage</a>
    </div>
  </div>
</section>


<!-- ============================================================
     SECTION 1: ACTIVITIES & EVENTS
     ============================================================ -->
<section class="py-16 md:py-24" id="activities">
  <div class="section-container">

    <div class="flex items-center gap-4 mb-12">
      <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center shrink-0">
        <span class="material-symbols-outlined text-on-primary text-xl">event</span>
      </div>
      <div>
        <p class="eyebrow mb-0.5">On the Ground</p>
        <h2 class="text-headline-md font-display text-on-surface">Activities &amp; Events</h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for activity in sitedata.activities %}
        <article class="card group flex flex-col gap-4 hover:border-primary/30 hover:shadow-[0_8px_32px_rgba(37,59,194,0.08)] transition-all duration-300">
          <div class="relative aspect-[16/9] overflow-hidden rounded-lg bg-surface-container">
            <img
              src="{{ activity.image }}"
              alt="{{ activity.title }}"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-primary text-on-primary text-label-md px-2 py-0.5 rounded-full font-semibold">
              {{ activity.type }}
            </span>
          </div>
          <div class="flex-1 flex flex-col gap-2">
            <p class="text-label-md text-on-surface-variant">{{ activity.date }}</p>
            <h3 class="text-headline-sm font-display text-on-surface group-hover:text-primary transition-colors">
              {{ activity.title }}
            </h3>
            <p class="text-body-md text-on-surface-variant leading-relaxed flex-1">{{ activity.description }}</p>
            <a href="{{ activity.href }}" class="inline-flex items-center gap-1.5 text-primary font-bold text-label-md hover:gap-2.5 transition-all mt-2">
              <span class="material-symbols-outlined text-base" style="font-variation-settings:'FILL' 1">check_circle</span>
              Read more
              <span class="material-symbols-outlined text-base">arrow_forward</span>
            </a>
          </div>
        </article>
      {% endfor %}

      <!-- Coming soon placeholder -->
      <div class="card border-dashed flex flex-col items-center justify-center gap-3 text-center py-12 opacity-40">
        <span class="material-symbols-outlined text-4xl text-on-surface-variant">edit_note</span>
        <p class="text-body-md text-on-surface-variant">More events coming soon</p>
      </div>
    </div>

  </div>
</section>


