<!-- ============================================================
     TEAM
     ============================================================ -->
<section class="py-16 bg-surface-off-white">
  <div class="section-container">
    <p class="eyebrow mb-4">Our Team</p>
    <h2 class="text-headline-md font-display text-on-surface mb-12">Meet the People Behind AKA Digital</h2>

    {# Headshots were never committed and are gone from the server — until they
       are re-supplied, cards feature event/activity cover photos (git-tracked
       under /images/hero/ so they survive deploys), all linking to Insights. #}
    {% set eventCovers = [
      "/images/hero/dss-2024.jpg",
      "/images/hero/home-summit.jpeg",
      "/images/hero/summit-hcm.jpeg",
      "/images/hero/solutions-summit.jpg",
      "/images/hero/workshop-cdp.jpeg"
    ] %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for person in team %}
        <div class="card flex flex-col gap-5 p-8">

          <!-- Event cover photo → Insights -->
          <a href="/insights" class="block rounded-xl overflow-hidden aspect-[16/9] group" aria-label="AKA Digital events and activities — see Insights">
            <img
              src="{{ eventCovers[loop.index0 % eventCovers.length] }}"
              alt="AKA Digital events & activities"
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </a>

          <!-- Avatar + name -->
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 rounded-full overflow-hidden bg-primary/10 shrink-0 flex items-center justify-center">
              <span class="font-display font-extrabold text-headline-sm text-primary">{{ person.name | truncate(2, true, "") }}</span>
            </div>
            <div>
              <p class="font-display font-bold text-headline-sm text-on-surface">{{ person.name }}</p>
              <p class="text-label-md text-primary font-bold uppercase tracking-wider mt-0.5">{{ person.role_label }}</p>
              <div class="flex items-center gap-2 mt-1 flex-wrap">
                {% if person.markets %}
                  {% for mkt in person.markets %}
                    <span class="text-base" aria-label="{{ mkt }}">
                      {% if mkt == "SG" %}🇸🇬{% elif mkt == "MY" %}🇲🇾{% elif mkt == "ID" %}🇮🇩{% elif mkt == "VN" %}🇻🇳{% elif mkt == "KR" %}🇰🇷{% elif mkt == "TH" %}🇹🇭{% else %}🌐{% endif %}
                    </span>
                  {% endfor %}
                {% else %}
                  <span class="text-base">
                    {% if person.country_code == "SG" %}🇸🇬{% elif person.country_code == "VN" %}🇻🇳{% elif person.country_code == "KR" %}🇰🇷{% else %}🌐{% endif %}
                  </span>
                {% endif %}
                <span class="text-body-md text-on-surface-variant">{{ person.country }}</span>
              </div>
            </div>
          </div>

          <!-- Contact -->
          <div class="pt-4 border-t border-outline-variant/20 space-y-2">
            <a href="mailto:{{ person.email }}" class="flex items-center gap-2 text-body-md text-primary hover:underline">
              <span class="material-symbols-outlined text-base shrink-0">mail</span>
              {{ person.email }}
            </a>
            <div class="flex items-center gap-2 text-body-md text-on-surface-variant">
              <span class="material-symbols-outlined text-base shrink-0">call</span>
              {{ person.phone }}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>


<!-- ============================================================
     IN THE FIELD — event photo strip
     ============================================================ -->
<section class="py-16 md:py-20">
  <div class="section-container">
    <div class="text-center mb-10">
      <p class="eyebrow mb-3">In the Field</p>
      <h2 class="text-headline-sm font-display text-on-surface">AKA Digital at Work Across Southeast Asia</h2>
    </div>
    <!-- Auto-scrolling photo strip -->
    <div class="relative overflow-hidden">
      <div class="flex gap-4 photo-scroll-track" style="animation: photoScroll 30s linear infinite;">
        {# Photos live in /images/events-strip/ — a git-tracked folder, because
           Hostinger deploys wipe anything untracked (the old
           /images/activities/ paths 404ed on live for exactly that reason). #}
        {% set eventPhotos = [
          "/images/events-strip/summit-hn-2023-01.jpg",
          "/images/events-strip/summit-hcm-01.jpeg",
          "/images/events-strip/martech-innovation-2023-01.jpeg",
          "/images/events-strip/summit-hn-2023-02.jpg",
          "/images/events-strip/summit-hcm-02.jpeg",
          "/images/events-strip/martech-innovation-2023-02.jpg",
          "/images/events-strip/summit-hn-2023-03.jpg",
          "/images/events-strip/summit-hcm-03.jpeg",
          "/images/events-strip/martech-innovation-2023-03.jpeg",
          "/images/events-strip/summit-hn-2023-04.jpg",
          "/images/events-strip/summit-hcm-04.jpeg",
          "/images/events-strip/summit-hn-2023-05.jpg"
        ] %}
        {% for photo in eventPhotos %}
          <a href="/insights" class="shrink-0 w-64 h-40 overflow-hidden rounded-2xl bg-surface-container block"
             aria-label="AKA Digital events — see Insights">
            <img src="{{ photo }}" alt="AKA Digital event"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy" />
          </a>
        {% endfor %}
        <!-- Duplicate for seamless loop -->
        {% for photo in eventPhotos %}
          <a href="/insights" class="shrink-0 w-64 h-40 overflow-hidden rounded-2xl bg-surface-container block" aria-hidden="true" tabindex="-1">
            <img src="{{ photo }}" alt=""
              class="w-full h-full object-cover"
              loading="lazy" />
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
<style>
@keyframes photoScroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.photo-scroll-track:hover { animation-play-state: paused; }
</style>


