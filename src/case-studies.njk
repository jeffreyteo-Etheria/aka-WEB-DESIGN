---
layout: layouts/base.njk
title: Case Studies | AKA Digital
description: Real results from real clients. Explore AKA Digital's award-winning MarTech case studies across Southeast Asia — from MMA Smarties winners to CDP implementations.
---

<!-- Hero -->
<section class="relative py-24 bg-white overflow-hidden">
  <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-primary/5 blur-[120px] pointer-events-none -translate-y-1/3 translate-x-1/4"></div>
  <div class="section-container relative z-10">
    <p class="eyebrow text-primary mb-4">Our Work</p>
    <h1 class="text-headline-lg font-display text-on-surface mb-6 max-w-2xl text-balance">
      Results That <span class="text-action-yellow">Speak</span> For Themselves
    </h1>
    <p class="text-body-lg text-on-surface-variant max-w-xl">
      Award-winning campaigns, data-driven transformations, and measurable business outcomes — across Southeast Asia's leading brands.
    </p>
    <!-- Stats strip -->
    <div class="flex flex-wrap gap-8 mt-10 pt-8 border-t border-on-surface/10">
      <div>
        <span class="block font-display font-extrabold text-headline-md text-action-yellow leading-none mb-1 notranslate" translate="no">4</span>
        <span class="text-label-md text-on-surface-variant uppercase tracking-wider">Key Pillar Solutions</span>
      </div>
      <div>
        <span class="block font-display font-extrabold text-headline-md text-action-yellow leading-none mb-1 notranslate" translate="no">6</span>
        <span class="text-label-md text-on-surface-variant uppercase tracking-wider">SEA Markets</span>
      </div>
      <div>
        <span class="block font-display font-extrabold text-headline-md text-action-yellow leading-none mb-1 notranslate" translate="no">150+</span>
        <span class="text-label-md text-on-surface-variant uppercase tracking-wider">Enterprise Brands</span>
      </div>
    </div>
  </div>
</section>

<!-- Category filter + grid -->
<section class="py-16 md:py-24">
  <div class="section-container">

    <!-- Filter tabs -->
    <div class="flex flex-wrap gap-2 mb-12" id="cs-filters">
      <button class="cs-filter active px-5 py-2.5 rounded-full text-label-md font-bold transition-all" data-filter="all">
        All Work
      </button>
      <button class="cs-filter px-5 py-2.5 rounded-full text-label-md font-bold transition-all" data-filter="social-influencer">
        Social &amp; Influencer
      </button>
      <button class="cs-filter px-5 py-2.5 rounded-full text-label-md font-bold transition-all" data-filter="programmatic-audio">
        Programmatic &amp; Audio
      </button>
      <button class="cs-filter px-5 py-2.5 rounded-full text-label-md font-bold transition-all" data-filter="crm-automation">
        CRM &amp; Automation
      </button>
      <button class="cs-filter px-5 py-2.5 rounded-full text-label-md font-bold transition-all" data-filter="travel-spark">
        Travel &amp; Spark
      </button>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="cs-grid">
      {% for study in case_studies %}
        {% set study = study %}
        <div class="cs-card" data-category="{{ study.category }}">
          {% include "components/case-study-card.njk" %}
        </div>
      {% endfor %}
    </div>

    <!-- Empty state -->
    <div id="cs-empty" class="hidden text-center py-24">
      <span class="material-symbols-outlined text-5xl text-on-surface-variant/40 mb-4 block">search_off</span>
      <p class="text-body-lg text-on-surface-variant">No case studies in this category yet.</p>
    </div>

  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-surface-off-white text-center">
  <div class="section-container">
    <p class="eyebrow mb-3">Work With Us</p>
    <h2 class="text-headline-md font-display text-on-surface mb-4">Your brand. Your story. Next.</h2>
    <p class="text-body-lg text-on-surface-variant mb-8 max-w-md mx-auto">
      Let's build a campaign worth writing about.
    </p>
    <a href="/contact" class="btn-primary">Start a Project</a>
  </div>
</section>

<style>
.cs-filter {
  background: transparent;
  border: 2px solid var(--color-outline-variant, #c5c5d7);
  color: var(--color-on-surface-variant, #454654);
}
.cs-filter:hover {
  border-color: var(--color-primary, #1B3A7A);
  color: var(--color-primary, #1B3A7A);
}
.cs-filter.active {
  background: var(--color-primary, #1B3A7A);
  border-color: var(--color-primary, #1B3A7A);
  color: #fff;
}
.cs-card { transition: opacity 0.25s ease, transform 0.25s ease; }
.cs-card.hidden { display: none; }
</style>

<script>
(function(){
  var filters = document.querySelectorAll('.cs-filter');
  var cards   = document.querySelectorAll('.cs-card');
  var empty   = document.getElementById('cs-empty');

  filters.forEach(function(btn){
    btn.addEventListener('click', function(){
      var cat = this.getAttribute('data-filter');
      filters.forEach(function(b){ b.classList.remove('active'); });
      this.classList.add('active');

      var visible = 0;
      cards.forEach(function(card){
        if (cat === 'all' || card.getAttribute('data-category') === cat) {
          card.classList.remove('hidden');
          visible++;
        } else {
          card.classList.add('hidden');
        }
      });
      empty.classList.toggle('hidden', visible > 0);
    });
  });
})();
</script>
