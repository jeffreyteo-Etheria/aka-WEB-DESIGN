---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>AKA Digital — MarTech Insights</title>
    <link>https://akadigital.net</link>
    <description>B2B MarTech insights, AI search strategy, and digital marketing from Southeast Asia's leading MarTech agency.</description>
    <language>en</language>
    <atom:link href="https://akadigital.net/feed.xml" rel="self" type="application/rss+xml" />
    {% for post in blogs | publishedOnly | sort(false, true, "date") %}{% if loop.index <= 20 %}
    <item>
      <title><![CDATA[{{ post.title }}]]></title>
      <link>https://akadigital.net/blog/{{ post.slug }}/</link>
      <guid isPermaLink="true">https://akadigital.net/blog/{{ post.slug }}/</guid>
      <pubDate>{{ post.date }}</pubDate>
      <description><![CDATA[{{ post.excerpt }}]]></description>
      <author>{{ post.author }}</author>
      {% if post.cover_image %}<media:content url="https://akadigital.net{{ post.cover_image }}" medium="image" />{% endif %}
      {% for tag in post.tags %}<category>{{ tag }}</category>
      {% endfor %}
    </item>
    {% endif %}{% endfor %}
  </channel>
</rss>
