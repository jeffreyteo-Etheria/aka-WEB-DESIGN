---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- Core pages -->
  <url><loc>{{ settings.siteUrl }}/</loc><changefreq>weekly</changefreq><priority>1.0</priority></url>
  <url><loc>{{ settings.siteUrl }}/about</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ settings.siteUrl }}/solutions</loc><changefreq>monthly</changefreq><priority>0.9</priority></url>
  <url><loc>{{ settings.siteUrl }}/solutions/crm-automation</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ settings.siteUrl }}/solutions/digital-programmatic</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ settings.siteUrl }}/solutions/geo-ai-seo</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ settings.siteUrl }}/solutions/social-media</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ settings.siteUrl }}/tech-partners</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  <url><loc>{{ settings.siteUrl }}/case-studies</loc><changefreq>weekly</changefreq><priority>0.9</priority></url>

  <!-- Case studies -->
  {% for cs in case_studies | publishedOnly %}
  <url><loc>{{ settings.siteUrl }}/case-studies/{{ cs.slug }}</loc><changefreq>monthly</changefreq><priority>0.8</priority></url>
  {% endfor %}

  <!-- Insights / Blog -->
  <url><loc>{{ settings.siteUrl }}/insights</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  {% for post in insights %}
  <url><loc>{{ settings.siteUrl }}/insights/{{ post.slug }}</loc><changefreq>monthly</changefreq><priority>0.6</priority></url>
  {% endfor %}

  <!-- Blog articles -->
  <url><loc>{{ settings.siteUrl }}/blog</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  {% for post in blogs | publishedOnly %}
  <url>
    <loc>{{ settings.siteUrl }}/blog/{{ post.slug }}</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
    {% if post.date %}<lastmod>{{ post.date }}</lastmod>{% endif %}
  </url>
  {% endfor %}

  <!-- Contact & other -->
  <url><loc>{{ settings.siteUrl }}/contact</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ settings.siteUrl }}/careers</loc><changefreq>monthly</changefreq><priority>0.5</priority></url>

</urlset>
